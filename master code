// ===================== RTX SYSTEM =====================
// Źródła światła — gracz + przeszkody + portale emitują światło
function rtx_getLights(){
  const lights=[];
  // Gracz — główne źródło
  const pcol=currentLevel?currentLevel.color:'#40c0f0';
  lights.push({x:player.x+player.size/2, y:player.y+player.size/2, r:180, color:pcol, intensity:1.0});
  // Przeszkody — kolce świecą czerwono
  for(const o of obstacles){
    if(o.x>-50&&o.x<W+50){
      lights.push({x:o.x+o.w/2, y:o.y+o.h/2, r:60, color:'#ff3030', intensity:0.5});
    }
  }
  // Portale
  for(const fp of flyPortals){
    lights.push({x:fp.x+fp.w/2, y:fp.y+fp.h/2, r:140, color:'#00ffff', intensity:0.8});
  }
  // Orby
  for(const orb of orbs){
    if(!orb.collected) lights.push({x:orb.x, y:orb.y, r:80, color:'#e060ff', intensity:0.7});
  }
  // Platformy
  for(const p of platforms){
    lights.push({x:p.x+p.w/2, y:p.y, r:50, color:'#30ff60', intensity:0.4});
  }
  return lights;
}

// Ray marching — sprawdza czy punkt jest w cieniu
function rtx_rayBlocked(lx,ly,px,py){
  const dx=px-lx, dy=py-ly;
  const dist=Math.sqrt(dx*dx+dy*dy);
  if(dist<2) return false;
  const steps=Math.floor(dist/8);
  for(let i=1;i<steps;i++){
    const t=i/steps;
    const rx=lx+dx*t, ry=ly+dy*t;
    for(const o of obstacles){
      if(rx>o.x&&rx<o.x+o.w&&ry>o.y&&ry<o.y+o.h) return true;
    }
  }
  return false;
}

// Odbicie na podłodze (screen-space reflection)
function rtx_drawFloorReflections(lights){
  ctx.save();
  // Odbicie gracza w podłodze
  const px=player.x+player.size/2;
  const reflY=GROUND+(player.y+player.size/2-GROUND)*-0.3+GROUND;
  const pcol=currentLevel?currentLevel.color:'#40c0f0';
  const refGrad=ctx.createRadialGradient(px,GROUND,0,px,GROUND,player.size*2.5);
  refGrad.addColorStop(0,pcol+'55');
  refGrad.addColorStop(1,'rgba(0,0,0,0)');
  ctx.fillStyle=refGrad;
  ctx.fillRect(0,GROUND,W,H-GROUND);
  // Odbicia przeszkód
  for(const o of obstacles){
    if(o.y+o.h<GROUND-5||o.x<-50||o.x>W+50) continue;
    const rg=ctx.createRadialGradient(o.x+o.w/2,GROUND,0,o.x+o.w/2,GROUND,o.w*1.5);
    rg.addColorStop(0,'rgba(255,48,48,0.2)');
    rg.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=rg;
    ctx.fillRect(o.x-o.w,GROUND,o.w*3,H*0.08);
  }
  ctx.restore();
}

// Globalne oświetlenie — ambient light map
function rtx_drawGlobalIllumination(lights){
  ctx.save();
  ctx.globalCompositeOperation='screen';
  for(const l of lights){
    if(l.intensity<0.3) continue;
    const blocked=rtx_rayBlocked(l.x,l.y,player.x+player.size/2,player.y+player.size/2);
    const fadeIntensity=blocked?0.15:l.intensity;
    const g=ctx.createRadialGradient(l.x,l.y,0,l.x,l.y,l.r);
    // Konwertuj kolor hex na rgba
    const hex=l.color.replace('#','');
    const r=parseInt(hex.substr(0,2),16)||255;
    const gr=parseInt(hex.substr(2,2),16)||255;
    const b2=parseInt(hex.substr(4,2),16)||255;
    g.addColorStop(0,`rgba(${r},${gr},${b2},${0.12*fadeIntensity})`);
    g.addColorStop(0.4,`rgba(${r},${gr},${b2},${0.05*fadeIntensity})`);
    g.addColorStop(1,`rgba(${r},${gr},${b2},0)`);
    ctx.fillStyle=g;
    ctx.beginPath();ctx.arc(l.x,l.y,l.r,0,Math.PI*2);ctx.fill();
  }
  ctx.restore();
}

// Cienie kierunkowe od obiektów
function rtx_drawShadows(lights){
  ctx.save();
  ctx.globalCompositeOperation='multiply';
  // Główne światło = gracz
  const mainLight=lights[0];
  if(!mainLight) return;
  for(const o of obstacles){
    if(o.x<-50||o.x>W+50) continue;
    const ox=o.x+o.w/2, oy=o.y+o.h/2;
    const dx=ox-mainLight.x, dy=oy-mainLight.y;
    const dist=Math.sqrt(dx*dx+dy*dy);
    if(dist<10) continue;
    const nx=dx/dist, ny=dy/dist;
    // Rzutuj cień za przeszkodą
    const shadowLen=Math.min(200, mainLight.r*0.8);
    const sx1=o.x, sy1=o.y;
    const sx2=o.x+o.w, sy2=o.y;
    const ex1=sx1+nx*shadowLen, ey1=sy1+ny*shadowLen;
    const ex2=sx2+nx*shadowLen, ey2=sy2+ny*shadowLen;
    const sg=ctx.createLinearGradient(ox,oy,ox+nx*shadowLen,oy+ny*shadowLen);
    sg.addColorStop(0,'rgba(0,0,0,0.35)');
    sg.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=sg;
    ctx.beginPath();
    ctx.moveTo(sx1,sy1);ctx.lineTo(sx2,sy2);
    ctx.lineTo(ex2,ey2);ctx.lineTo(ex1,ey1);
    ctx.closePath();ctx.fill();
  }
  ctx.globalCompositeOperation='source-over';
  ctx.restore();
}

// Świetlne obwódki (specular highlight)
function rtx_drawSpecular(lights){
  ctx.save();
  ctx.globalCompositeOperation='screen';
  for(const l of lights){
    if(l.intensity<0.5) continue;
    // Highlight na graczu
    const dx=player.x+player.size/2-l.x;
    const dy=player.y+player.size/2-l.y;
    const dist=Math.sqrt(dx*dx+dy*dy);
    if(dist>l.r) continue;
    const falloff=1-(dist/l.r);
    const hx=player.x+player.size*0.3;
    const hy=player.y+player.size*0.25;
    ctx.fillStyle=`rgba(255,255,255,${0.18*falloff*l.intensity})`;
    ctx.beginPath();ctx.ellipse(hx,hy,player.size*0.25,player.size*0.12,-0.3,0,Math.PI*2);ctx.fill();
  }
  ctx.restore();
}

// Główna funkcja RTX — wywołana w draw()
function rtx_render(){
  if(qualityMode!=='rtx') return;
  const lights=rtx_getLights();
  rtx_drawGlobalIllumination(lights);
  rtx_drawShadows(lights);
  rtx_drawFloorReflections(lights);
  rtx_drawSpecular(lights);
  // Winietka RTX
  ctx.save();
  const vig=ctx.createRadialGradient(W/2,H/2,H*0.2,W/2,H/2,H*0.85);
  vig.addColorStop(0,'rgba(0,0,0,0)');
  vig.addColorStop(1,'rgba(0,0,10,0.35)');
  ctx.fillStyle=vig;ctx.fillRect(0,0,W,H);
  // Etykieta RTX ON w rogu
  ctx.font='bold 11px monospace';ctx.fillStyle='rgba(0,200,255,0.6)';
  ctx.textAlign='right';ctx.textBaseline='top';
  ctx.fillText('💎 RTX ON',W-70,6);
  ctx.restore();
}


// Animowane tło głównego menu — latające kwadraty GD
let _mmRaf=null;
function mainMenu_animBg(){
  if(_mmRaf) cancelAnimationFrame(_mmRaf);
  const bg=document.getElementById('main-menu-bg');
  // canvas w tle
  let mc=bg.querySelector('canvas');
  if(!mc){mc=document.createElement('canvas');mc.style.cssText='position:absolute;inset:0;width:100%;height:100%;';bg.appendChild(mc);}
  mc.width=window.innerWidth;mc.height=window.innerHeight;
  const mctx=mc.getContext('2d');
  const cubes=Array.from({length:18},()=>({
    x:Math.random()*mc.width,y:Math.random()*mc.height,
    vx:(Math.random()-.5)*0.8,vy:(Math.random()-.5)*0.8,
    size:Math.random()*30+12,rot:Math.random()*360,
    rotSpd:(Math.random()-.5)*1.2,
    color:`hsl(${Math.random()*360},70%,55%)`,alpha:Math.random()*0.18+0.04,
  }));
  function frame(){
    if(document.getElementById('main-menu').style.display==='none'){_mmRaf=null;return;}
    _mmRaf=requestAnimationFrame(frame);
    mctx.clearRect(0,0,mc.width,mc.height);
    for(const c of cubes){
      c.x+=c.vx;c.y+=c.vy;c.rot+=c.rotSpd;
      if(c.x<-50)c.x=mc.width+50;if(c.x>mc.width+50)c.x=-50;
      if(c.y<-50)c.y=mc.height+50;if(c.y>mc.height+50)c.y=-50;
      mctx.save();mctx.globalAlpha=c.alpha;
      mctx.translate(c.x,c.y);mctx.rotate(c.rot*Math.PI/180);
      mctx.fillStyle=c.color;mctx.strokeStyle='rgba(255,255,255,0.3)';mctx.lineWidth=1.5;
      mctx.fillRect(-c.size/2,-c.size/2,c.size,c.size);
      mctx.strokeRect(-c.size/2,-c.size/2,c.size,c.size);
      mctx.restore();
    }
  }
  frame();
}

// ===================== MUZYKA (Web Audio API) =====================
let audioCtx=null;
let musicNodes=[];
let musicPlaying='';
let musicVol=0.7;

function audioInit(){
  if(audioCtx) return;
  audioCtx=new(window.AudioContext||window.webkitAudioContext)();
}

function musicStop(){
  musicNodes.forEach(n=>{try{n.stop(0);}catch(e){}});
  musicNodes=[];
  musicPlaying='';
}

function makeOsc(freq,type,startT,dur,vol,atk=0.01,rel=0.05){
  if(!audioCtx||musicVol<=0) return;
  const g=audioCtx.createGain();
  g.connect(audioCtx.destination);
  g.gain.setValueAtTime(0,startT);
  g.gain.linearRampToValueAtTime(vol*musicVol,startT+atk);
  g.gain.setValueAtTime(vol*musicVol,startT+dur-rel);
  g.gain.linearRampToValueAtTime(0,startT+dur);
  const o=audioCtx.createOscillator();
  o.type=type;o.frequency.value=freq;
  o.connect(g);o.start(startT);o.stop(startT+dur);
  musicNodes.push(o);
}

function makeKick(startT,vol=0.5){
  if(!audioCtx) return;
  const o=audioCtx.createOscillator();
  const g=audioCtx.createGain();
  o.connect(g);g.connect(audioCtx.destination);
  o.type='sine';
  o.frequency.setValueAtTime(160,startT);
  o.frequency.exponentialRampToValueAtTime(35,startT+0.15);
  g.gain.setValueAtTime(vol*musicVol,startT);
  g.gain.exponentialRampToValueAtTime(0.001,startT+0.2);
  o.start(startT);o.stop(startT+0.2);
  musicNodes.push(o);
}

function makeSnare(startT,vol=0.18){
  if(!audioCtx) return;
  const o=audioCtx.createOscillator();
  const g=audioCtx.createGain();
  o.connect(g);g.connect(audioCtx.destination);
  o.type='square';o.frequency.value=180+Math.random()*80;
  g.gain.setValueAtTime(vol*musicVol,startT);
  g.gain.exponentialRampToValueAtTime(0.001,startT+0.1);
  o.start(startT);o.stop(startT+0.1);
  musicNodes.push(o);
}

function makeHat(startT,vol=0.03){
  if(!audioCtx) return;
  const o=audioCtx.createOscillator();
  const g=audioCtx.createGain();
  const f=audioCtx.createBiquadFilter();
  f.type='highpass';f.frequency.value=7000;
  o.type='square';o.frequency.value=8000+Math.random()*4000;
  o.connect(f);f.connect(g);g.connect(audioCtx.destination);
  g.gain.setValueAtTime(vol*musicVol,startT);
  g.gain.exponentialRampToValueAtTime(0.001,startT+0.035);
  o.start(startT);o.stop(startT+0.035);
  musicNodes.push(o);
}

// ---- MENU GŁÓWNE: house/electro 128BPM ----
function musicPlayMenu(){
  if(musicPlaying==='menu') return;
  musicStop();audioInit();
  if(audioCtx.state==='suspended') audioCtx.resume();
  musicPlaying='menu';
  const b=60/128, t=audioCtx.currentTime+0.05;
  function bar(s){
    if(musicPlaying!=='menu') return;
