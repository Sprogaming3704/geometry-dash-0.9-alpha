function drawSkinPreview(canvas2d, skinId, col){
  const c=canvas2d;
  const w=c.width||60, h=c.height||60;
  const x=w/2, y=h/2, s=w*0.78;
  c.clearRect(0,0,w,h);
  if(skinId===0){
    // Sześcian
    c.shadowColor=col;c.shadowBlur=8;c.fillStyle=col;
    c.fillRect(x-s/2,y-s/2,s,s);
    c.fillStyle='#fff';c.shadowBlur=0;
    c.fillRect(x-s*0.18,y-s*0.18,s*0.36,s*0.36);
    c.fillStyle=col;
    const d=s*0.28;
    [[-1,-1],[1,-1],[1,1],[-1,1]].forEach(([dx,dy])=>{c.beginPath();c.arc(x+dx*d/2,y+dy*d/2,s*0.07,0,Math.PI*2);c.fill();});
  } else if(skinId===1){
    // Ramki
    c.shadowColor=col;c.shadowBlur=8;
    c.fillStyle=col+'66';c.fillRect(x-s/2,y-s/2,s,s);
    c.strokeStyle=col;c.lineWidth=2;c.shadowBlur=6;
    c.strokeRect(x-s/2+2,y-s/2+2,s-4,s-4);
    c.strokeRect(x-s/2+7,y-s/2+7,s-14,s-14);
    c.shadowBlur=0;c.fillStyle='#fff';
    c.beginPath();c.arc(x,y,s*0.13,0,Math.PI*2);c.fill();
  } else if(skinId===2){
    // Gold
    c.shadowColor='#ffd040';c.shadowBlur=10;
    c.fillStyle='#ffaa00';c.fillRect(x-s/2,y-s/2,s,s);
    c.strokeStyle='rgba(255,255,180,0.8)';c.lineWidth=2;c.shadowBlur=0;
    c.strokeRect(x-s/2+2,y-s/2+2,s-4,s-4);
    c.fillStyle='#fff';c.font=`${Math.floor(s*0.5)}px serif`;
    c.textAlign='center';c.textBaseline='middle';
    c.fillText('★',x,y+1);
  } else if(skinId===3){
    // Kostka Rubika
    const cs=s/3;
    const colors=[['#ff0000','#ff0000','#ff0000'],['#ffff00','#ffff00','#ffff00'],['#ffff00','#ffff00','#ffff00']];
    for(let r=0;r<3;r++) for(let cc=0;cc<3;cc++){
      c.fillStyle='#111';c.fillRect(x-s/2+cc*cs,y-s/2+r*cs,cs,cs);
      c.fillStyle=colors[r][cc];c.fillRect(x-s/2+cc*cs+2,y-s/2+r*cs+2,cs-4,cs-4);
    }
    // Prawa ściana (niebieski)
    c.fillStyle='#0000cc';
    c.beginPath();c.moveTo(x+s/2,y-s/2);c.lineTo(x+s/2+s*0.2,y-s/2-s*0.1);
    c.lineTo(x+s/2+s*0.2,y+s/2-s*0.1);c.lineTo(x+s/2,y+s/2);c.fill();
    // Górna ściana (czerwony)
    c.fillStyle='#cc0000';
    c.beginPath();c.moveTo(x-s/2,y-s/2);c.lineTo(x+s/2,y-s/2);
    c.lineTo(x+s/2+s*0.2,y-s/2-s*0.1);c.lineTo(x-s/2+s*0.2,y-s/2-s*0.1);c.fill();
  } else if(skinId===4){
    // Prezent
    c.fillStyle='#ffffff';c.fillRect(x-s/2,y-s*0.35,s,s*0.85);
    c.strokeStyle='#ddd';c.lineWidth=1;c.strokeRect(x-s/2,y-s*0.35,s,s*0.85);
    // Wstążka pozioma
    c.fillStyle='#cc0000';c.fillRect(x-s/2,y-s*0.05,s,s*0.15);
    // Wstążka pionowa
    c.fillStyle='#cc0000';c.fillRect(x-s*0.08,y-s*0.35,s*0.16,s*0.85);
    // Kokarda
    c.fillStyle='#ee1111';
    c.beginPath();c.ellipse(x-s*0.15,y-s*0.38,s*0.15,s*0.1,-0.4,0,Math.PI*2);c.fill();
    c.beginPath();c.ellipse(x+s*0.15,y-s*0.38,s*0.15,s*0.1,0.4,0,Math.PI*2);c.fill();
    c.fillStyle='#ff2222';c.beginPath();c.arc(x,y-s*0.35,s*0.09,0,Math.PI*2);c.fill();
  } else if(skinId===5){
    // Potwór GD (szary z zębami)
    c.fillStyle='#888888';c.fillRect(x-s/2,y-s/2,s,s);
    c.strokeStyle='#222';c.lineWidth=2;c.strokeRect(x-s/2,y-s/2,s,s);
    // Oczy
    const er=s*0.14;
    [[-0.22,0.22],[0.22,0.22]].forEach(([ox,oy])=>{ // zamienione: oczy w górnej połowie
      c.fillStyle='#222';c.beginPath();c.arc(x+ox*s,y-oy*s,er,0,Math.PI*2);c.fill();
      c.fillStyle='#fff';c.beginPath();c.arc(x+ox*s-er*0.2,y-oy*s-er*0.2,er*0.4,0,Math.PI*2);c.fill();
    });
    // Zęby (zygzak na dole)
    c.fillStyle='#fff';c.beginPath();
    c.moveTo(x-s/2,y+s/2);
    for(let i=0;i<6;i++){
      const tx=x-s/2+i*(s/6)+(s/12);
      c.lineTo(tx,y+s*0.05);
      c.lineTo(tx+s/12,y+s/2);
    }
    c.closePath();c.fill();
    c.strokeStyle='#222';c.lineWidth=1;c.stroke();
  } else if(skinId===6){
    // Diamentowy blok Minecraft
    const dc='#4de6e6';
    c.fillStyle=dc;c.fillRect(x-s/2,y-s/2,s,s);
    // Wzór diamentu
    c.fillStyle='rgba(255,255,255,0.35)';
    c.fillRect(x-s/2,y-s/2,s,s*0.25);
    c.fillStyle='rgba(0,150,150,0.3)';
    c.fillRect(x-s*0.1,y-s*0.1,s*0.2,s*0.2);
    // Pixel art efekt — siatka
    c.strokeStyle='rgba(0,180,180,0.3)';c.lineWidth=0.5;
    for(let i=0;i<6;i++){
      c.beginPath();c.moveTo(x-s/2+i*s/6,y-s/2);c.lineTo(x-s/2+i*s/6,y+s/2);c.stroke();
      c.beginPath();c.moveTo(x-s/2,y-s/2+i*s/6);c.lineTo(x+s/2,y-s/2+i*s/6);c.stroke();
    }
    c.strokeStyle='rgba(100,255,255,0.8)';c.lineWidth=2;
    c.strokeRect(x-s/2+1,y-s/2+1,s-2,s-2);
    // Highlight
    c.fillStyle='rgba(255,255,255,0.5)';
    c.fillRect(x-s/2+3,y-s/2+3,s*0.3,s*0.12);
  } else if(skinId===7){
    // Command block Minecraft
    c.fillStyle='#c8845a';c.fillRect(x-s/2,y-s/2,s,s);
    // Płytki
    c.fillStyle='#b87040';
    [[0,0],[s*0.5,0],[0,s*0.5],[s*0.5,s*0.5]].forEach(([ox,oy])=>{
      c.fillRect(x-s/2+ox+2,y-s/2+oy+2,s*0.4,s*0.4);
    });
    // Środkowy panel
    c.fillStyle='#888';c.fillRect(x-s*0.28,y-s*0.28,s*0.56,s*0.56);
    c.fillStyle='#666';c.fillRect(x-s*0.22,y-s*0.22,s*0.44,s*0.44);
    // Kolorowe kropki na panelu
    const dots=[['#ff4444','#44ff44'],['#4444ff','#ffff44']];
    dots.forEach(([c1,c2],r)=>{
      [[c1,c2],[c2,c1]].forEach(([dc1],cc)=>{
        c.fillStyle=dc1;c.beginPath();c.arc(x-s*0.1+cc*s*0.2,y-s*0.08+r*s*0.18,s*0.04,0,Math.PI*2);c.fill();
      });
    });
    c.strokeStyle='rgba(255,200,150,0.5)';c.lineWidth=1.5;c.strokeRect(x-s/2+1,y-s/2+1,s-2,s-2);
  } else if(skinId===8){
    // GD Frog (zielony z oczami)
    c.fillStyle='#00dd44';c.fillRect(x-s/2,y-s/2,s,s);
    c.strokeStyle='#000';c.lineWidth=3;c.strokeRect(x-s/2,y-s/2,s,s);
    // Gradient
    const fg=c.createLinearGradient(x-s/2,y-s/2,x+s/2,y+s/2);
    fg.addColorStop(0,'rgba(100,255,150,0.4)');fg.addColorStop(1,'rgba(0,100,30,0.2)');
    c.fillStyle=fg;c.fillRect(x-s/2,y-s/2,s,s);
    // Oczy
    [[-0.2,0.18],[0.2,0.18]].forEach(([ox,oy])=>{
      c.fillStyle='#fff';c.beginPath();c.arc(x+ox*s,y-oy*s,s*0.18,0,Math.PI*2);c.fill();
      c.strokeStyle='#000';c.lineWidth=2;c.stroke();
      c.fillStyle='#000';c.beginPath();c.arc(x+ox*s,y-oy*s,s*0.08,0,Math.PI*2);c.fill();
    });
    // Usta
    c.fillStyle='#000';c.beginPath();c.arc(x,y+s*0.1,s*0.12,0,Math.PI);c.fill();
  }
}

function loadShopSkinsIntoArray(){
  const db=acc_getDB();
  const shop=db._shop||[];
  while(SKINS.length>9) SKINS.pop();
  shop.forEach((sk,i)=>{
    SKINS.push({
      id:100+i,
      name:sk.name,
      unlocked:true,
      shopSkin:true,
      pages:sk.pages,
      author:sk.author,
      price:sk.price,
      effects:sk.effects||{},
      border:sk.border,
      borderColor:sk.borderColor||'#ffffff',
      borderBlur:sk.borderBlur||8,
      pixelMode:sk.pixelMode!==false,
    });
  });
}

function drawShopSkinPreview(canvas2d, sk){
  const c=canvas2d;
  const w=c.width||60, h=c.height||60;
  c.clearRect(0,0,w,h);
  c.fillStyle='#0a0a1a'; c.fillRect(0,0,w,h);
  // image-rendering przez style canvasa
  if(c.canvas) c.canvas.style.imageRendering=sk.pixelMode!==false?'pixelated':'auto';
  const ps=w/SE_SIZE;
  (sk.pages&&sk.pages[0]||[]).forEach((col,i)=>{
    if(!col) return;
    const r=Math.floor(i/SE_SIZE), cc=i%SE_SIZE;
    c.fillStyle=col;
    c.fillRect(cc*ps, r*ps, ps, ps);
  });
  // Obramowanie tylko jeśli włączone
  if(sk.border!==false){
    c.strokeStyle=sk.borderColor||'rgba(255,255,255,0.9)';
    c.lineWidth=2;
    c.shadowColor=sk.borderColor||'#ffffff';
    c.shadowBlur=sk.borderBlur||8;
    c.strokeRect(1,1,w-2,h-2);
    c.shadowBlur=0;
  }
}

function buildSkinGridBig(){
  loadShopSkinsIntoArray();
  const grid=document.getElementById('skin-grid-big');
  if(!grid) return;
  grid.innerHTML='';
  SKINS.forEach((sk,i)=>{
    const card=document.createElement('div');
    card.className='skin-card'+(i===selectedSkin?' selected':'');
    const cv=document.createElement('canvas');
    cv.width=60;cv.height=60;
    if(sk.shopSkin){
      drawShopSkinPreview(cv.getContext('2d'), sk);
    } else {
      drawSkinPreview(cv.getContext('2d'),sk.id,'#40c0f0');
    }
    const lbl=document.createElement('span');
    lbl.textContent=sk.name;
    if(sk.shopSkin){
      const au=document.createElement('span');
      au.textContent=`by ${sk.author||'?'}`;
      au.style.cssText='color:#555;font-size:9px;display:block;';
      card.appendChild(cv);card.appendChild(lbl);card.appendChild(au);
    } else {
      card.appendChild(cv);card.appendChild(lbl);
    }
    card.onclick=()=>{selectedSkin=i;buildSkinGridBig();};
    grid.appendChild(card);
  });
}

