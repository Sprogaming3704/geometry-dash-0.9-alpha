// ===================== SPAWNING =====================
function spawnObstacleChunk(x,lv){
  // Poziom miejski — inne przeszkody
  if(lv.isCity){
    const r=Math.random();
    if(r<0.3){
      obstacles.push({x,y:GROUND-TILE*0.7,w:TILE*0.5,h:TILE*0.7,type:'block',cityObj:'🚒'});
    } else if(r<0.55){
      obstacles.push({x,y:GROUND-TILE*1.4,w:TILE*0.4,h:TILE*1.4,type:'block',cityObj:'🚧'});
    } else if(r<0.75){
      obstacles.push({x,y:GROUND-TILE,w:TILE,h:TILE,type:'block',cityObj:'📦'});
    } else if(r<0.88){
      obstacles.push({x,y:GROUND-TILE,w:TILE,h:TILE,type:'spike'});
    } else {
      obstacles.push({x,y:GROUND-TILE*2,w:TILE*0.5,h:TILE*2,type:'block',cityObj:'🏗️'});
    }
    return;
  }
  const easy=lv.obstacleOnly;
  const r=Math.random();
  // Nowe typy — pojawiają się od poziomu id>=1
  const canNew=!easy&&lv.id>=1;
  if(easy){
    const er=Math.random();
    if(er<0.7) obstacles.push({x,y:GROUND-TILE,w:TILE,h:TILE,type:'spike'});
    else        obstacles.push({x,y:GROUND-TILE*0.55,w:TILE*1.4,h:TILE*0.55,type:'jumppad',pulse:0});
  } else if(r<0.18){
    obstacles.push({x,y:GROUND-TILE,w:TILE,h:TILE,type:'spike'});
  } else if(r<0.33){
    obstacles.push({x,y:GROUND-TILE,w:TILE,h:TILE,type:'spike'});
    obstacles.push({x:x+TILE*1.1,y:GROUND-TILE,w:TILE,h:TILE,type:'spike'});
  } else if(r<0.44){
    obstacles.push({x,y:GROUND-TILE,w:TILE,h:TILE,type:'block'});
  } else if(r<0.54){
    obstacles.push({x,y:GROUND-TILE*2,w:TILE,h:TILE*2,type:'block'});
  } else if(r<0.63){
    obstacles.push({x,y:GROUND-TILE,w:TILE,h:TILE,type:'spike'});
    obstacles.push({x:x+TILE*2.2,y:GROUND-TILE,w:TILE,h:TILE,type:'spike'});
  } else if(r<0.71){
    obstacles.push({x,y:GROUND-TILE,w:TILE,h:TILE,type:'block'});
    obstacles.push({x:x+TILE*1.1,y:GROUND-TILE*2,w:TILE,h:TILE*2,type:'block'});
  } else if(canNew&&r<0.78){
    // Podkładka do skoku (jumppad)
    obstacles.push({x,y:GROUND-TILE*0.55,w:TILE*1.6,h:TILE*0.55,type:'jumppad',pulse:0});
  } else if(canNew&&r<0.84){
    // Blok po którym można chodzić (walkblock)
    obstacles.push({x,y:GROUND-TILE*1.5,w:TILE*2.5,h:TILE,type:'walkblock'});
    if(Math.random()<0.5) obstacles.push({x:x+TILE,y:GROUND-TILE*2.5,w:TILE,h:TILE,type:'spike'});
  } else if(canNew&&r<0.90){
    // Wysuwane kolce (sliding spike — wysuwa się co 1s)
    obstacles.push({x,y:GROUND-TILE,w:TILE,h:TILE,type:'spike-slide',slideTimer:0,slideOut:true});
  } else if(canNew){
    // Spadający kolec (z sufitu)
    obstacles.push({x:x+TILE*0.5,y:0,w:TILE,h:TILE,type:'spike-fall',vy:0,fallen:false});
  }
}

function spawnPlatformChunk(x){
  const count=1+Math.floor(Math.random()*2);
  const levels=[GROUND-TILE*2.5,GROUND-TILE*3.5,GROUND-TILE*4.5];
  for(let i=0;i<count;i++){
    const px=x+i*TILE*(3+Math.random()*2);
    const py=levels[Math.floor(Math.random()*levels.length)];
    const pw=TILE*(2+Math.random()*2);
    platforms.push({x:px,y:py,w:pw,h:TILE*0.45});
    // Na Impossible — kolce na platformach (rzadziej)
    if(currentLevel&&currentLevel.id===6&&Math.random()<0.5){
      const sx=px+(pw-TILE)*0.5;
      obstacles.push({x:sx,y:py-TILE,w:TILE,h:TILE,type:'spike'});
    }
  }
  if(Math.random()<0.3) obstacles.push({x:x+TILE*0.5,y:GROUND-TILE,w:TILE,h:TILE,type:'spike'});
}

function spawnOrbChunk(x){
  orbs.push({x,y:GROUND-TILE*3.2,r:TILE*0.42,collected:false,pulse:0});
  if(Math.random()<0.45) obstacles.push({x:x+TILE*3,y:GROUND-TILE*2,w:TILE,h:TILE*2,type:'block'});
}

function spawnChunk(x,lv){
  const gap=lv.gapMin+Math.random()*lv.gapRand;
  // Portal latania — nie dla miasta
  if(!lv.isCity){
    const flyIntervals={0:TILE*120, 1:TILE*110, 2:TILE*130, 3:TILE*150, 4:TILE*180, 5:TILE*200, 6:TILE*220};
    const flyInt = flyIntervals[lv.id] || TILE*50;
    if(!flyMode && x > flyPortalSpawnX + flyInt){
      flyPortalSpawnX = x;
      flyPortals.push({x:x+TILE*3, y:0, w:TILE*2, h:GROUND, pulse:0});
      return x + TILE*gap;
    }
  }
  // Miasto — dużo platform i przeszkód miejskich
  if(lv.isCity){
    const r=Math.random();
    if(r<0.25){
      // Rząd platform dachowych
      spawnPlatformChunk(x); spawnPlatformChunk(x+TILE*3); spawnPlatformChunk(x+TILE*6);
      spawnObstacleChunk(x+TILE*2,lv);
    } else if(r<0.5){
      // Schodkowe platformy
      platforms.push({x:x,       y:GROUND-TILE*2, w:TILE*2, h:TILE*0.45});
      platforms.push({x:x+TILE*2,y:GROUND-TILE*3, w:TILE*2, h:TILE*0.45});
      platforms.push({x:x+TILE*4,y:GROUND-TILE*4, w:TILE*2, h:TILE*0.45});
      spawnObstacleChunk(x+TILE*1,lv);
    } else if(r<0.7){
      // Platformy z przeszkodami
      spawnPlatformChunk(x); spawnPlatformChunk(x+TILE*5);
      spawnObstacleChunk(x+TILE*3,lv); spawnObstacleChunk(x+TILE*7,lv);
    } else if(r<0.85){
      // Tylko przeszkody miejskie
      spawnObstacleChunk(x,lv); spawnObstacleChunk(x+TILE*3,lv);
      spawnPlatformChunk(x+TILE*5);
    } else {
      // Orb + platformy
      spawnOrbChunk(x+TILE*2);
      spawnPlatformChunk(x); spawnPlatformChunk(x+TILE*4); spawnPlatformChunk(x+TILE*8);
    }
    return x+TILE*gap;
  }
  if(lv.obstacleOnly){
    spawnObstacleChunk(x,lv);
    return x+TILE*gap;
  }
  const r=Math.random();
  if(r<0.3){
    spawnObstacleChunk(x,lv);
    spawnPlatformChunk(x+TILE*4);
  } else if(r<0.5){
    spawnPlatformChunk(x);
    spawnObstacleChunk(x+TILE*5,lv);
    if(Math.random()<0.5) spawnOrbChunk(x+TILE*2);
  } else if(r<0.65){
    spawnOrbChunk(x);
    spawnPlatformChunk(x+TILE*3);
    spawnObstacleChunk(x+TILE*7,lv);
  } else if(r<0.8){
    spawnPlatformChunk(x);
    spawnPlatformChunk(x+TILE*5);
    spawnOrbChunk(x+TILE*3);
  } else {
    spawnObstacleChunk(x,lv);
    spawnOrbChunk(x+TILE*4);
    spawnPlatformChunk(x+TILE*6);
    spawnObstacleChunk(x+TILE*10,lv);
  }
  return x+TILE*gap;
}

