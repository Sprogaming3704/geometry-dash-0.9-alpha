function seUpdatePreview(){
  seBorderColor=document.getElementById('se-border-color')?.value||'#ffffff';
  seBorderBlur=parseInt(document.getElementById('se-border-blur')?.value)||8;
  const cv=document.getElementById('se-preview-fx');
  if(!cv) return;
  const pc=cv.getContext('2d');
  const sz=cv.width;
  const t=Date.now();
  pc.clearRect(0,0,sz,sz);
  pc.fillStyle='#0a0a1a';pc.fillRect(0,0,sz,sz);
  cv.style.imageRendering=sePixelMode?'pixelated':'auto';
  cv.style.filter='';

  // Efekty na tle (promień światła)
  if(seEffects.light){
    for(let i=0;i<4;i++){
      const angle=(t/800)+(i/4)*Math.PI*2;
      const hue=seEffects.colorchange?(t/15+i*90)%360:55;
      const g=pc.createLinearGradient(sz/2,sz/2,sz/2+Math.cos(angle)*sz*1.5,sz/2+Math.sin(angle)*sz*1.5);
      g.addColorStop(0,`hsla(${hue},100%,80%,0.45)`);
      g.addColorStop(1,`hsla(${hue},100%,80%,0)`);
      pc.fillStyle=g;
      pc.beginPath();pc.moveTo(sz/2,sz/2);
      const sp=0.22;
      pc.lineTo(sz/2+Math.cos(angle-sp)*sz*2,sz/2+Math.sin(angle-sp)*sz*2);
      pc.lineTo(sz/2+Math.cos(angle+sp)*sz*2,sz/2+Math.sin(angle+sp)*sz*2);
      pc.closePath();pc.fill();
    }
  }

  // Efekty cień/glow
  if(seEffects.shadow){pc.shadowColor='rgba(0,0,0,0.8)';pc.shadowBlur=10;pc.shadowOffsetX=4;pc.shadowOffsetY=4;}
  if(seEffects.glow){pc.shadowColor='#cc66ff';pc.shadowBlur=18;pc.shadowOffsetX=0;pc.shadowOffsetY=0;}

  // Rysuj piksele
  const ps=sz/SE_SIZE;
  sePages[sePage].forEach((col2,i)=>{
    if(!col2) return;
    const r=Math.floor(i/SE_SIZE),c2=i%SE_SIZE;
    let dc=col2;
    if(seEffects.rainbow) dc=`hsl(${(t/10+i*7)%360},100%,55%)`;
    else if(seEffects.colorchange) dc=`hsl(${(t/15+i*5)%360},90%,55%)`;
    if(seEffects.pulse) pc.globalAlpha=0.6+Math.sin(t*0.004+i*0.1)*0.4;
    pc.fillStyle=dc;
    pc.fillRect(c2*ps,r*ps,ps,ps);
    pc.globalAlpha=1;
  });
  pc.shadowBlur=0;pc.shadowOffsetX=0;pc.shadowOffsetY=0;

  // Obramowanie
  if(seBorder){
    pc.strokeStyle=seBorderColor;pc.lineWidth=2;
    pc.shadowColor=seBorderColor;pc.shadowBlur=seBorderBlur;
    pc.strokeRect(1,1,sz-2,sz-2);pc.shadowBlur=0;
  }

  // Gwiazdki orbitujące
  if(seEffects.stars){
    for(let i=0;i<5;i++){
      const angle=t/600+(i/5)*Math.PI*2;
      const orbitR=sz*0.52;
      const sx2=sz/2+Math.cos(angle)*orbitR;
      const sy2=sz/2+Math.sin(angle)*orbitR;
      const starSz=sz*0.1+Math.sin(t/300+i)*sz*0.03;
      const hue=seEffects.colorchange?(t/15+i*60)%360:50;
      pc.fillStyle=`hsl(${hue},100%,70%)`;
      pc.shadowColor=`hsl(${hue},100%,85%)`;pc.shadowBlur=8;
      pc.font=`${Math.floor(starSz*2)}px serif`;
      pc.textAlign='center';pc.textBaseline='middle';
      pc.fillText('✦',sx2,sy2);
    }
    pc.shadowBlur=0;
  }

  // Drżenie
  cv.style.transform=seEffects.shake?`translate(${(Math.random()-0.5)*3}px,${(Math.random()-0.5)*3}px)`:'';
  requestAnimationFrame(()=>{ if(document.getElementById('op-panel-skineditor')?.style.display!=='none') seUpdatePreview(); });
}

