<script>
// ===================== SYSTEM ANIMACJI =====================

// Transition overlay
const transOverlay=document.getElementById('transition-overlay');

function animTransition(color1='#30c060',color2='#06060f',cb=null,duration=400){
  transOverlay.style.background=`radial-gradient(circle,${color1}cc,${color2}f0)`;
  transOverlay.style.transition=`opacity ${duration/2}ms`;
  transOverlay.classList.add('active');
  setTimeout(()=>{
    if(cb) cb();
    setTimeout(()=>{
      transOverlay.style.transition=`opacity ${duration/2}ms`;
      transOverlay.classList.remove('active');
    },80);
  },duration/2);
}

// Animuj elementy listy z kaskadą delay
function animateList(selector,animClass='anim-slideFade',baseDelay=0){
  const els=document.querySelectorAll(selector);
  els.forEach((el,i)=>{
    el.style.animation='none';
    el.style.opacity='0';
    setTimeout(()=>{
      el.style.animation='';
      el.classList.remove(animClass);
      void el.offsetWidth; // reflow
      el.classList.add(animClass);
      el.style.animationDelay=`${i*0.06}s`;
      el.style.opacity='';
    },baseDelay+i*60);
  });
}

// Animuj pojedynczy element
function animEl(el,animClass,cb=null,duration=400){
  if(!el) return;
  el.classList.remove(animClass);
  void el.offsetWidth;
  el.classList.add(animClass);
  if(cb) setTimeout(cb,duration);
}

// Efekt ripple na przycisku
function addRipple(btn){
  btn.addEventListener('click',function(e){
    const r=document.createElement('span');
    const rect=btn.getBoundingClientRect();
    const size=Math.max(rect.width,rect.height);
    r.style.cssText=`position:absolute;width:${size}px;height:${size}px;
      left:${e.clientX-rect.left-size/2}px;top:${e.clientY-rect.top-size/2}px;
      background:rgba(255,255,255,0.25);border-radius:50%;pointer-events:none;
      animation:ripple 0.5s ease-out forwards;`;
    btn.style.position='relative';btn.style.overflow='hidden';
    btn.appendChild(r);
    setTimeout(()=>r.remove(),500);
  });
}

// Dodaj ripple do wszystkich przycisków
document.querySelectorAll('.main-btn,.lvl-btn,.login-btn,.op-tab,.skin-card').forEach(addRipple);

// ===== ANIMACJE EKRANÓW =====

// Sweep efekt przy przejściu między ekranami
function screenSweep(showEl,color='#30c060',cb=null){
  animTransition(color,'#06060f',()=>{
    if(showEl) animEl(showEl,'anim-fadeIn');
    if(cb) cb();
  },350);
}

// Animacja startowa menu głównego
function animMainMenu(){
  const logo=document.getElementById('main-title');
  const btns=document.querySelectorAll('#main-buttons .main-btn');
  const ver=document.getElementById('main-version');

  if(logo){ logo.style.animation='none'; void logo.offsetWidth; logo.classList.add('anim-slideDown'); }

  btns.forEach((btn,i)=>{
    btn.style.opacity='0';
    setTimeout(()=>{
      btn.style.opacity='';
      btn.classList.remove('anim-slideUp');
      void btn.offsetWidth;
      btn.classList.add('anim-slideUp');
      btn.style.animationDelay=`${i*0.08}s`;
    },200+i*80);
  });

  if(ver){ setTimeout(()=>animEl(ver,'anim-fadeIn'),600); }
}

// Animacja ekranu poziomów
function animLevelScreen(){
  const title=document.getElementById('screen-title');
  const sub=document.getElementById('screen-sub');
  const grid=document.getElementById('level-grid');
  const ws=document.getElementById('world-selector');

  if(ws) animEl(ws,'anim-slideDown');
  if(title){ setTimeout(()=>animEl(title,'anim-slideLeft'),100); }
  if(sub){ setTimeout(()=>animEl(sub,'anim-fadeIn'),200); }
  if(grid){ setTimeout(()=>animateList('#level-grid .lvl-btn','anim-popIn',250),250); }
}

// Animacja przycisku GRAJ
function animPlayButton(){
  const btn=document.getElementById('btn-play');
  if(btn){ btn.classList.add('anim-tada'); setTimeout(()=>btn.classList.remove('anim-tada'),600); }
}

// Animacja ładowania poziomu
function animLevelLoading(lvName,color){
  const icon=document.getElementById('ll-icon');
  const name=document.getElementById('ll-name');
