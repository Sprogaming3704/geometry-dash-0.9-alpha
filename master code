function die(){
  if(state==='dead') return; // zapobiegaj wielokrotnemu wywołaniu
  spawnParticles(player.x+player.size/2,player.y+player.size/2,currentLevel.color,28);
  flash.style.opacity='1'; setTimeout(()=>{flash.style.opacity='0';},150);

  lives--;
  updateLivesUI();

  if(lives>0){
    player.y=GROUND-TILE; player.vy=0; player.onGround=true; player.onPlatform=false;
    player.rotation=0; player.doubleJumps=0; player.usedDoubleJump=false;
    flyMode=false; flySpikes=[]; flyPortals=[]; flyVy=0; flyInvincible=0; flyDistance=0;
    hideFlyControls();
    musicStop();
    musicPlayGame(currentLevel.id||0, currentLevel.trackId);
    if(currentLevel.custom){
      obstacles=[...currentLevel.customObstacles.map(o=>({...o}))];
      orbs=[...currentLevel.customOrbs.map(o=>({...o}))];
      platforms=[...currentLevel.customPlatforms.map(p=>({...p}))];
      flyPortals=[...currentLevel.customPortals.map(p=>({...p}))];
      nextSpawnX=999999;
      flyPortalSpawnX=999999;
    } else {
      obstacles=[]; orbs=[]; platforms=[];
      nextSpawnX=W+150;
      for(let i=0;i<10;i++) nextSpawnX=spawnChunk(nextSpawnX,currentLevel);
    }
    return;
  }

  // No lives left
  state='dead';
  musicPlayLevelSelect();
  const li=currentLevel.id;
  const pct = currentLevel.infinite
    ? Math.floor(levelProgress)
    : currentLevel.custom
      ? Math.round((levelProgress/currentLevel.customLength)*100)
      : Math.round((levelProgress/(LEVEL_LENGTHS[li]||LEVEL_LENGTH))*100);
  if(pct>bestPcts[li]) bestPcts[li]=pct;
  fxOverlay.style.opacity='0';
  canvas.style.filter='';
  canvas.style.transform='';

  screenTitle.innerHTML=`${pct}%`;
  screenTitle.style.fontSize='90px';
  screenSub.textContent=`Zginąłeś na poziomie ${currentLevel.name}! Czas: ${levelTime.toFixed(2)}s. Kliknij aby wrócić do menu.`;
  actionBtn.style.display='none';
  buildLevelGrid();
  updateBestTxt();
  screenEl.style.display='flex';
}

function win(){
  state='win';
  musicPlayLevelSelect();
  const li=currentLevel.id;
  bestPcts[li]=100;
  // Monety za ukończenie poziomu (nie dla specjalnych kont)
  if(!['owner','admin','tester'].includes(currentRole)){
    coins+=100;
    acc_saveProgress();
    showCoinPopup('+100 🪙', 'poziom ukończony!');
  }
  // unlock next level
  if(li+1<LEVELS.length && li+1<51) unlockedLevels[li+1]=true;
  if(li===0) unlockedLevels[2]=true;
  if(li===2) SKINS[1].unlocked=true;
  if(li===3) SKINS[2].unlocked=true;
  if(li===3) unlockedLevels[10]=true;
  if(li===9) unlockedLevels[21]=true; // Bóstwo odblokowuje Świat Wody (id 21)
  // Odblokowuj kolejne poziomy Świata Wody
  if(li>=21 && li<50) unlockedLevels[li+1]=true;
  fxOverlay.style.opacity='0';

  screenTitle.innerHTML='100% 🎉';
  screenTitle.style.fontSize='72px';
  screenSub.textContent=`POZIOM ${currentLevel.name.toUpperCase()} UKOŃCZONY w ${levelTime.toFixed(2)}s! Następny odblokowany!`;
  actionBtn.style.display='none';
  buildLevelGrid();
  updateBestTxt();
  screenEl.style.display='flex';
  // Animacje wygranej
  flashScreen('rgba(80,255,120,0.4)',400);
