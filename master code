    if(el) el.style.display='flex';
    // Ukryj login
    const ls=document.getElementById('login-screen');
    if(ls) ls.style.display='none';
    return; // Stop — nie inicjalizuj gry
  }

  // Jeśli jesteśmy na iOS ale przez serwer (Safari) — OK, graj normalnie
  // Jeśli Android z lokalnym plikiem — pokaż ostrzeżenie ale pozwól grać
  if(isLocalFile&&!isIOS){
    console.warn('Lokalny plik — niektóre funkcje mogą nie działać');
  }
})();
function applyResponsiveLayout(){
  const mob=isMobile();
  const portrait=window.innerHeight>window.innerWidth;
  if(mob){
    document.body.style.touchAction='none';
    const mb=document.getElementById('mobile-btn');
    if(mb){
      mb.style.height=portrait?'90px':'60px';
      mb.style.fontSize=portrait?'22px':'16px';
    }
    const fps=document.getElementById('fps-counter');
    if(fps){fps.style.fontSize='9px';fps.style.padding='1px 4px';}
    const cu=document.getElementById('coins-ui');
    if(cu) cu.style.fontSize='12px';
    const ju=document.getElementById('jumps-ui');
    if(ju) ju.style.display=portrait?'':'none';
  } else {
    const mb=document.getElementById('mobile-btn');
    if(mb){mb.style.height='80px';mb.style.fontSize='28px';}
    const fps=document.getElementById('fps-counter');
    if(fps){fps.style.fontSize='12px';fps.style.padding='2px 7px';}
    const ju=document.getElementById('jumps-ui');
    if(ju) ju.style.display='';
  }
}
applyResponsiveLayout();
// Domyślna rozdzielczość 50%
applyResolution('1.0');
window.addEventListener('resize',()=>{onResize();applyResponsiveLayout();});
window.addEventListener('orientationchange',()=>setTimeout(()=>{onResize();applyResponsiveLayout();},350));

generateStars();

function loop(){
  // FPS
  fpsCounter++;
  const now=performance.now();
  if(now-fpsTime>=500){
    fpsDisplay=Math.round(fpsCounter*1000/(now-fpsTime));
    fpsCounter=0; fpsTime=now;
    fpsEl.textContent=fpsDisplay+' FPS';
    fpsEl.style.color=fpsDisplay>=55?'rgba(0,255,100,0.7)':fpsDisplay>=30?'rgba(255,200,0,0.8)':'rgba(255,60,60,0.9)';
  }
  try{ update(); draw(); }
  catch(e){ console.error(e); }
  requestAnimationFrame(loop);
}
loop();
</script>
