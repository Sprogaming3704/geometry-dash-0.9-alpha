let citySkinIdx=0;

// ===================== 3D RENDERER =====================
let d3_obstacles=[];   // {z, lane, type}  lane: 0=L,1=C,2=R
let d3_playerLane=1;   // 0=L,1=C,2=R
let d3_laneTarget=1;
let d3_laneX=0;        // płynne przejście
let d3_z=0;            // pozycja kamery Z (postęp)
let d3_speed=0.18;
let d3_nextZ=8;
let d3_invincible=0;
let d3_moveLeft=false, d3_moveRight=false;

const D3_LANE_XS=[-1, 0, 1]; // pozycje pasów w jednostkach świata
const D3_FOV=500;
const D3_HORIZON=0.42; // % wysokości ekranu
const D3_COLORS={
  floor:   ['#0a0a1a','#0d0d22'],
  wall:    '#0a1428',
  ceiling: '#050510',
  grid:    '#00ffff',
  obs:     '#ff3030',
  obsGlow: '#ff0000',
  player:  '#00ffff',
};

function d3_project(wx, wy, wz){
  // wx,wy,wz — pozycja w przestrzeni świata względem kamery
  const fz = wz;
  if(fz<=0.01) return null;
  const sx = W/2 + (wx/fz)*D3_FOV;
  const sy = H*D3_HORIZON - (wy/fz)*D3_FOV;
  const scale = D3_FOV/fz;
  return {sx, sy, scale};
}

function d3_init(){
  d3_obstacles=[];
  d3_z=0; d3_nextZ=8; d3_speed=0.18;
  d3_playerLane=1; d3_laneTarget=1; d3_laneX=0;
  d3_invincible=0; d3_moveLeft=false; d3_moveRight=false;
  // wygeneruj pierwsze przeszkody
  for(let i=0;i<20;i++) d3_spawnObs();
}

function d3_spawnObs(){
  const type=Math.random()<0.6?'wall':'floor'; // wall=ściana blokująca pas, floor=kolec na podłodze
  const lane=Math.floor(Math.random()*3);
  d3_obstacles.push({z:d3_nextZ, lane, type, hit:false});
  d3_nextZ += 3+Math.random()*4;
}

function d3_update(){
  if(!currentLevel.is3D) return;
  levelProgress += speed;
  levelTime += 1/60;
  timerUI.textContent = levelTime.toFixed(2)+'s';
  d3_z += d3_speed;
  d3_speed = 0.18 + levelProgress/80000;

  // Płynne przejście między pasami
  const targetX = D3_LANE_XS[d3_laneTarget];
  d3_laneX += (targetX - d3_laneX)*0.18;

  // Usuń stare przeszkody
  d3_obstacles=d3_obstacles.filter(o=>o.z-d3_z>-1);
  // Generuj nowe
  const lastZ=d3_obstacles.length>0?d3_obstacles[d3_obstacles.length-1].z:d3_z;
  if(lastZ-d3_z<30) d3_spawnObs();

  // Kolizje
  if(d3_invincible>0){ d3_invincible--; return; }
  for(const o of d3_obstacles){
    const dz=o.z-d3_z;
    if(dz<1.2&&dz>-0.5&&o.lane===d3_laneTarget&&!o.hit){
      o.hit=true;
      spawnParticles(W/2,H*0.6,'#ff3030',20);
      flash.style.opacity='1'; setTimeout(()=>{flash.style.opacity='0';},150);
      lives--;
      updateLivesUI();
      d3_invincible=90;
      if(lives<=0) die();
      return;
    }
  }
}

function d3_draw(){
  ctx.clearRect(0,0,W,H);
  const hz=H*D3_HORIZON;

  // Sufit
  ctx.fillStyle='#050510';
  ctx.fillRect(0,0,W,hz);

  // Podłoga — gradient perspektywiczny
  const floorGrad=ctx.createLinearGradient(0,hz,0,H);
  floorGrad.addColorStop(0,'#0a0a1a');
  floorGrad.addColorStop(1,'#141428');
  ctx.fillStyle=floorGrad;
  ctx.fillRect(0,hz,W,H-hz);

  // Siatka podłogi
  ctx.strokeStyle='rgba(0,255,255,0.25)'; ctx.lineWidth=1;
  // linie biegnące w dal (pionowe w perspektywie)
  for(let lx=-4;lx<=4;lx++){
    const far=d3_project(lx*2,  -0.5, 40);
    const near=d3_project(lx*2, -0.5, 1.5);
    if(!far||!near) continue;
    ctx.beginPath(); ctx.moveTo(near.sx,near.sy); ctx.lineTo(far.sx,far.sy); ctx.stroke();
  }
  // linie poprzeczne
  for(let iz=1;iz<40;iz++){
    const wz=iz-(d3_z%1);
    if(wz<1.5) continue;
    const l=d3_project(-8,-0.5,wz);
    const r=d3_project( 8,-0.5,wz);
    if(!l||!r) continue;
    ctx.globalAlpha=Math.min(1, wz/4*0.3);
    ctx.beginPath(); ctx.moveTo(l.sx,l.sy); ctx.lineTo(r.sx,r.sy); ctx.stroke();
  }
  ctx.globalAlpha=1;

  // Ściany boczne korytarza
  const wallDist=3.5;
  for(const side of [-1,1]){
    ctx.save();
    const wallGrad=ctx.createLinearGradient(side>0?W:0,0,W/2,0);
    wallGrad.addColorStop(0,'rgba(0,100,180,0.4)');
    wallGrad.addColorStop(1,'rgba(0,50,120,0)');
    ctx.fillStyle=wallGrad;
    // trapez ściany
    const farT=d3_project(side*wallDist, 2, 40);
    const farB=d3_project(side*wallDist,-0.5,40);
    const nearT=d3_project(side*wallDist, 2, 1.5);
    const nearB=d3_project(side*wallDist,-0.5,1.5);
    if(farT&&farB&&nearT&&nearB){
      ctx.beginPath();
      ctx.moveTo(nearT.sx,nearT.sy); ctx.lineTo(farT.sx,farT.sy);
      ctx.lineTo(farB.sx,farB.sy);  ctx.lineTo(nearB.sx,nearB.sy);
      ctx.closePath(); ctx.fill();
    }
    // linie siatki ścian
    ctx.strokeStyle='rgba(0,200,255,0.15)'; ctx.lineWidth=1;
    for(let iz=2;iz<40;iz+=3){
      const wz=iz-(d3_z%3);
      if(wz<1.5) continue;
      const t=d3_project(side*wallDist,2,wz);
      const b=d3_project(side*wallDist,-0.5,wz);
      if(t&&b){ctx.beginPath();ctx.moveTo(t.sx,t.sy);ctx.lineTo(b.sx,b.sy);ctx.stroke();}
    }
    ctx.restore();
  }

  // Przeszkody
  for(const o of d3_obstacles){
    const dz=o.z-d3_z;
    if(dz<0.5||dz>35) continue;
    const lx=D3_LANE_XS[o.lane];
    const alpha=Math.min(1,(dz-0.5)/3);
    ctx.save(); ctx.globalAlpha=alpha;

    if(o.type==='wall'){
      // Ściana blokująca pas — wysoki prostokąt
      const tl=d3_project(lx-0.85, 1.8, dz);
      const tr=d3_project(lx+0.85, 1.8, dz);
      const bl=d3_project(lx-0.85,-0.5, dz);
      const br=d3_project(lx+0.85,-0.5, dz);
      if(tl&&tr&&bl&&br){
        const glow=o.hit?0:0.8+Math.sin(Date.now()/200)*0.2;
        ctx.shadowColor='#ff2020'; ctx.shadowBlur=20*glow;
        ctx.fillStyle=`rgba(180,20,20,${0.85})`;
        ctx.beginPath();
        ctx.moveTo(tl.sx,tl.sy);ctx.lineTo(tr.sx,tr.sy);
        ctx.lineTo(br.sx,br.sy);ctx.lineTo(bl.sx,bl.sy);
        ctx.closePath(); ctx.fill();
        ctx.strokeStyle='#ff4040'; ctx.lineWidth=2; ctx.shadowBlur=8;
        ctx.stroke();
        // Krzyż ostrzegawczy
        ctx.strokeStyle='rgba(255,100,100,0.6)'; ctx.lineWidth=1.5;
        ctx.beginPath();
        ctx.moveTo(tl.sx,tl.sy);ctx.lineTo(br.sx,br.sy);ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(tr.sx,tr.sy);ctx.lineTo(bl.sx,bl.sy);ctx.stroke();
      }
    } else {
      // Kolec na podłodze
      const tip=d3_project(lx, 0.9, dz);
      const bl= d3_project(lx-0.6,-0.5,dz);
      const br= d3_project(lx+0.6,-0.5,dz);
      if(tip&&bl&&br){
        ctx.shadowColor='#ff4400'; ctx.shadowBlur=16;
        ctx.fillStyle='rgba(220,60,0,0.9)';
        ctx.beginPath();
        ctx.moveTo(tip.sx,tip.sy);ctx.lineTo(bl.sx,bl.sy);ctx.lineTo(br.sx,br.sy);
        ctx.closePath(); ctx.fill();
        ctx.strokeStyle='#ff6600'; ctx.lineWidth=1.5; ctx.stroke();
      }
    }
    ctx.restore();
  }

  // Wskaźniki pasów (strzałki na dole)
  const laneScreenX=[W*0.3, W*0.5, W*0.7];
  for(let i=0;i<3;i++){
    ctx.save();
    ctx.globalAlpha= i===d3_laneTarget ? 1.0 : 0.25;
    ctx.strokeStyle= i===d3_laneTarget ? '#00ffff' : '#336688';
    ctx.lineWidth=3; ctx.shadowColor='#00ffff'; ctx.shadowBlur= i===d3_laneTarget?18:0;
    // trójkąt wskaźnika
    ctx.beginPath();
    ctx.moveTo(laneScreenX[i], H*0.85);
    ctx.lineTo(laneScreenX[i]-18, H*0.92);
    ctx.lineTo(laneScreenX[i]+18, H*0.92);
    ctx.closePath(); ctx.stroke();
    ctx.restore();
  }

  // Gracz — świecąca kula 3D na dole ekranu
  const px=W/2 + d3_laneX*W*0.19;
  const py=H*0.78;
  const pr=H*0.055;
  const inv=d3_invincible>0;
  ctx.save();
  if(inv&&Math.floor(Date.now()/80)%2===0){ ctx.globalAlpha=0.3; }
  const pGrad=ctx.createRadialGradient(px-pr*0.3,py-pr*0.3,pr*0.1,px,py,pr);
  pGrad.addColorStop(0,'#ffffff');
  pGrad.addColorStop(0.3,'#00ffff');
  pGrad.addColorStop(1,'rgba(0,100,200,0.3)');
  ctx.shadowColor='#00ffff'; ctx.shadowBlur=30;
  ctx.fillStyle=pGrad;
  ctx.beginPath(); ctx.arc(px,py,pr,0,Math.PI*2); ctx.fill();
  ctx.restore();

  // Vignette
  const vg=ctx.createRadialGradient(W/2,H/2,H*0.3,W/2,H/2,H*0.9);
  vg.addColorStop(0,'rgba(0,0,0,0)');
  vg.addColorStop(1,'rgba(0,0,10,0.7)');
  ctx.fillStyle=vg; ctx.fillRect(0,0,W,H);

  // Progress bar
  const effLen=LEVEL_LENGTHS[18]||12000;
  const pct=Math.min(1,levelProgress/effLen);
  ctx.fillStyle='rgba(255,255,255,0.07)'; ctx.fillRect(0,H-6,W,6);
  const pg=ctx.createLinearGradient(0,0,W,0);
  pg.addColorStop(0,'#00ffff'); pg.addColorStop(1,'#0044ff');
  ctx.fillStyle=pg; ctx.shadowColor='#00ffff'; ctx.shadowBlur=6;
  ctx.fillRect(0,H-6,W*pct,6); ctx.shadowBlur=0;
}


function draw(){
  if(currentLevel&&currentLevel.is3D){ d3_draw(); return; }
  if(!theme) return;
  ctx.clearRect(0,0,W,H);

  // Zastosuj kamerę
  ctx.save();
  ctx.translate(0, cameraY);

  // Tło — unikalne dla każdego poziomu
  const grd=ctx.createLinearGradient(0,0,0,GROUND);
  grd.addColorStop(0,theme.sky1);grd.addColorStop(1,theme.sky2);
  ctx.fillStyle=grd;ctx.fillRect(0,0,W,GROUND);

  const t=Date.now()/1000;
  const lv=currentLevel;

  if(lv.id===0){
    // ŁATWY — nocne niebo z gwiazdami i księżycem
    ctx.save();
    ctx.fillStyle='rgba(255,255,220,0.9)';ctx.shadowColor='#ffffaa';ctx.shadowBlur=20;
    ctx.beginPath();ctx.arc(W*0.85,GROUND*0.18,TILE*0.6,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='rgba(10,20,50,0.6)';
    ctx.beginPath();ctx.arc(W*0.85+TILE*0.2,GROUND*0.18-TILE*0.1,TILE*0.5,0,Math.PI*2);ctx.fill();
    ctx.restore();
  } else if(lv.id===1){
    // BONUS — disco kule i kolory
    for(let i=0;i<6;i++){
      const bx=((i*200+t*40)%( W+100))-50;
      const by=GROUND*(0.1+i*0.08);
      const col=`hsl(${(i*60+t*60)%360},100%,60%)`;
      ctx.save();ctx.fillStyle=col;ctx.shadowColor=col;ctx.shadowBlur=30;
      ctx.globalAlpha=0.25;ctx.beginPath();ctx.arc(bx,by,TILE*1.5,0,Math.PI*2);ctx.fill();
      ctx.restore();
    }
  } else if(lv.id===2){
    // ŚREDNI — galaktyka spiralna
    ctx.save();ctx.globalAlpha=0.15;
    for(let i=0;i<60;i++){
      const angle=i*0.45+t*0.05;
      const r=i*TILE*0.18;
      const sx=W*0.5+Math.cos(angle)*r;
      const sy=GROUND*0.4+Math.sin(angle)*r*0.4;
      ctx.fillStyle=`hsl(${220+i*2},80%,70%)`;
      ctx.beginPath();ctx.arc(sx,sy,1.5,0,Math.PI*2);ctx.fill();
    }
    ctx.restore();
  } else if(lv.id===3){
    // TRUDNY — jaskinia z stalaktytami
    ctx.save();
    ctx.fillStyle='rgba(20,8,4,0.7)';ctx.fillRect(0,0,W,GROUND);
    ctx.fillStyle='#2a1208';ctx.shadowColor='#ff4400';ctx.shadowBlur=6;
    for(let i=0;i<12;i++){
      const sx=((i*137+levelProgress*0.3)%(W+80))-40;
      const sh=TILE*(1.5+Math.sin(i*2.3)*0.8);
      ctx.beginPath();ctx.moveTo(sx-TILE*0.4,0);ctx.lineTo(sx+TILE*0.4,0);ctx.lineTo(sx,sh);ctx.closePath();ctx.fill();
    }
    // Stalatyty od dołu
    ctx.fillStyle='#1a0a04';
    for(let i=0;i<10;i++){
      const sx=((i*173+levelProgress*0.25)%(W+80))-40;
      const sh=TILE*(1+Math.sin(i*1.7)*0.6);
      ctx.beginPath();ctx.moveTo(sx-TILE*0.35,GROUND);ctx.lineTo(sx+TILE*0.35,GROUND);ctx.lineTo(sx,GROUND-sh);ctx.closePath();ctx.fill();
    }
    ctx.restore();
  } else if(lv.id===4){
    // DIABEŁ — płonące piekło z ogniem
    ctx.save();
    for(let i=0;i<8;i++){
      const fx=((i*157+levelProgress*0.5)%(W+60))-30;
      const fh=TILE*(1.5+Math.sin(t*3+i)*0.5);
      const fg=ctx.createLinearGradient(fx,GROUND-fh,fx,GROUND);
      fg.addColorStop(0,'rgba(255,50,0,0)');fg.addColorStop(0.5,'rgba(255,100,0,0.3)');fg.addColorStop(1,'rgba(255,150,0,0.5)');
      ctx.fillStyle=fg;ctx.fillRect(fx-TILE*0.5,GROUND-fh,TILE,fh);
    }
    ctx.restore();
  } else if(lv.id===5){
    // PIEKŁO — lawa bulgocząca
    ctx.save();
    ctx.globalAlpha=0.2;
    for(let i=0;i<6;i++){
      const lx=((i*200+levelProgress*0.4)%(W+100))-50;
      const ly=GROUND-TILE*(0.3+Math.sin(t*2+i)*0.2);
      const lg=ctx.createRadialGradient(lx,ly,0,lx,ly,TILE*2);
      lg.addColorStop(0,'#ffaa00');lg.addColorStop(1,'rgba(255,30,0,0)');
      ctx.fillStyle=lg;ctx.beginPath();ctx.arc(lx,ly,TILE*2,0,Math.PI*2);ctx.fill();
    }
    ctx.restore();
  } else if(lv.id===6){
    // IMPOSSIBLE — matrix cyfry
    ctx.save();ctx.font=`${TILE*0.35}px monospace`;ctx.textAlign='center';
    for(let i=0;i<20;i++){
      const mx=((i*97+levelProgress*0.8)%(W+20));
      const my=GROUND*(0.1+((i*137)%100)/150);
      ctx.fillStyle=`rgba(0,255,0,${0.05+Math.sin(t*2+i)*0.05})`;
      ctx.fillText(Math.floor(Math.random()*2),mx,my);
    }
    ctx.restore();
  } else if(lv.id===7){
    // KOSZMAR — fioletowe oko w tle
    ctx.save();ctx.globalAlpha=0.12;
    const eyeR=TILE*3;
    ctx.fillStyle='#6600aa';ctx.shadowColor='#aa00ff';ctx.shadowBlur=40;
    ctx.beginPath();ctx.arc(W*0.5,GROUND*0.4,eyeR,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#000';ctx.shadowBlur=0;
    ctx.beginPath();ctx.arc(W*0.5+Math.cos(t)*TILE*0.8,GROUND*0.4+Math.sin(t)*TILE*0.5,eyeR*0.4,0,Math.PI*2);ctx.fill();
    ctx.restore();
  } else if(lv.id===8){
    // OTCHŁAŃ — spirala wciągająca
    ctx.save();ctx.globalAlpha=0.12;
    for(let i=0;i<30;i++){
      const angle=i*0.5+t*0.3;
      const r=TILE*(i*0.25+0.5);
      const sx=W*0.5+Math.cos(angle)*r;
      const sy=GROUND*0.4+Math.sin(angle)*r*0.5;
      ctx.fillStyle=`hsl(${160+i*4},100%,50%)`;
      ctx.beginPath();ctx.arc(sx,sy,2,0,Math.PI*2);ctx.fill();
    }
    ctx.restore();
  } else if(lv.id===9){
    // BÓSTWO — promienie słoneczne
    ctx.save();ctx.globalAlpha=0.08;
    const cx=W*0.5,cy=-TILE;
    for(let i=0;i<12;i++){
      const angle=(i/12)*Math.PI*2+t*0.1;
      ctx.fillStyle=`hsl(${45+i*10},100%,70%)`;
      ctx.beginPath();ctx.moveTo(cx,cy);
      ctx.lineTo(cx+Math.cos(angle-0.15)*W,cy+Math.sin(angle-0.15)*W);
      ctx.lineTo(cx+Math.cos(angle+0.15)*W,cy+Math.sin(angle+0.15)*W);
      ctx.closePath();ctx.fill();
    }
    ctx.restore();
  } else if(lv.id===12){
    // KOSMOS — mgławica i planety
    ctx.save();
    const nebGrad=ctx.createRadialGradient(W*0.3,GROUND*0.3,0,W*0.3,GROUND*0.3,TILE*5);
    nebGrad.addColorStop(0,'rgba(80,0,160,0.12)');nebGrad.addColorStop(1,'rgba(0,0,60,0)');
    ctx.fillStyle=nebGrad;ctx.fillRect(0,0,W,GROUND);
    // Planety
    ctx.fillStyle='rgba(80,120,200,0.35)';ctx.shadowColor='#4488ff';ctx.shadowBlur=20;
    ctx.beginPath();ctx.arc(W*0.75,GROUND*0.25,TILE*1.2,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='rgba(180,80,40,0.3)';ctx.shadowColor='#ff6633';ctx.shadowBlur=15;
    ctx.beginPath();ctx.arc(W*0.2,GROUND*0.35,TILE*0.7,0,Math.PI*2);ctx.fill();
    ctx.restore();
  } else if(lv.id===13){
    // PODWODNY — bąbelki i glony
    ctx.save();
    ctx.fillStyle='rgba(0,80,140,0.2)';ctx.fillRect(0,0,W,GROUND);
    // Bąbelki
    for(let i=0;i<15;i++){
      const bx=((i*113+levelProgress*0.3)%(W+20));
      const by=GROUND*(0.2+((i*79+t*20+i*30)%100)/130);
      ctx.fillStyle='rgba(150,220,255,0.2)';ctx.strokeStyle='rgba(150,220,255,0.4)';ctx.lineWidth=1;
      ctx.beginPath();ctx.arc(bx,by,TILE*0.12,0,Math.PI*2);ctx.fill();ctx.stroke();
    }
    // Glony
    for(let i=0;i<8;i++){
      const gx=((i*177+levelProgress*0.2)%(W+40))-20;
      ctx.strokeStyle='rgba(0,180,100,0.35)';ctx.lineWidth=3;ctx.lineCap='round';
      ctx.beginPath();ctx.moveTo(gx,GROUND);
      ctx.quadraticCurveTo(gx+Math.sin(t+i)*TILE*0.8,GROUND-TILE,gx,GROUND-TILE*1.8);ctx.stroke();
    }
    ctx.restore();
  } else if(lv.id===14){
    // DŻUNGLA — liście i ptaki
    ctx.save();
    ctx.fillStyle='rgba(0,40,0,0.3)';ctx.fillRect(0,0,W,GROUND);
    // Liście
    for(let i=0;i<10;i++){
      const lx=((i*163+levelProgress*0.4)%(W+60))-30;
      ctx.fillStyle=`rgba(${20+i*5},${100+i*8},${20},0.4)`;
      ctx.beginPath();ctx.ellipse(lx,GROUND*0.15+i%3*TILE,TILE*0.8,TILE*0.3,Math.sin(t+i)*0.4,0,Math.PI*2);ctx.fill();
    }
    // Ptaki
    for(let i=0;i<4;i++){
      const bx=((i*250+t*60+i*80)%(W+80))-40;
      const by=GROUND*(0.1+i*0.07);
      ctx.strokeStyle='rgba(30,30,20,0.5)';ctx.lineWidth=2;
      ctx.beginPath();ctx.moveTo(bx,by);ctx.quadraticCurveTo(bx+10,by-5,bx+20,by);ctx.stroke();
      ctx.beginPath();ctx.moveTo(bx,by);ctx.quadraticCurveTo(bx-10,by-5,bx-20,by);ctx.stroke();
    }
    ctx.restore();
  } else if(lv.id===15){
    // LÓD — płatki śniegu i zorza
    ctx.save();
    // Zorza polarna
    for(let i=0;i<4;i++){
      const ag=ctx.createLinearGradient(0,0,0,GROUND);
      ag.addColorStop(0,`hsla(${140+i*30},100%,60%,0.04)`);
      ag.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=ag;
      ctx.save();ctx.translate(W*(0.2+i*0.2),0);
      ctx.fillRect(-W*0.12,0,W*0.24,GROUND);
      ctx.restore();
    }
    // Płatki śniegu
    for(let i=0;i<20;i++){
      const sx=((i*113+levelProgress*0.2)%(W+20));
      const sy=((i*79+levelProgress*0.15)%GROUND);
      ctx.fillStyle='rgba(200,230,255,0.5)';
      ctx.font=`${TILE*0.2}px serif`;ctx.textAlign='center';
      ctx.fillText('❄',sx,sy);
    }
    ctx.restore();
  } else if(lv.id===16){
    // WULKAN — lawa i dym
    ctx.save();
    // Dym
    for(let i=0;i<6;i++){
      const sx=W*0.5+((i*97+levelProgress*0.3)%(W*0.6))-W*0.3;
      const sy=GROUND*(0.1+Math.sin(t*0.5+i)*0.1);
      const sg=ctx.createRadialGradient(sx,sy,0,sx,sy,TILE*1.5);
      sg.addColorStop(0,'rgba(60,50,50,0.15)');sg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=sg;ctx.beginPath();ctx.arc(sx,sy,TILE*1.5,0,Math.PI*2);ctx.fill();
    }
    // Lawa spływająca
    for(let i=0;i<5;i++){
      const lx=((i*200+levelProgress*0.35)%(W+80))-40;
      ctx.fillStyle=`rgba(255,${60+i*15},0,0.15)`;
      ctx.fillRect(lx,GROUND-TILE*0.8,TILE*0.3,TILE*0.8);
    }
    ctx.restore();
  } else if(lv.id===17){
    // ... (prawie niemożliwy) — chaos
    ctx.save();ctx.globalAlpha=0.15;
    for(let i=0;i<8;i++){
      const cx2=((i*157+t*80+i*40)%W);
      const cy2=GROUND*(0.2+i%4*0.15);
      const cg=ctx.createRadialGradient(cx2,cy2,0,cx2,cy2,TILE*2);
      cg.addColorStop(0,`hsl(${(t*120+i*45)%360},100%,60%)`);
      cg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=cg;ctx.beginPath();ctx.arc(cx2,cy2,TILE*2,0,Math.PI*2);ctx.fill();
    }
    ctx.restore();
  } else if(lv.isRetro){
    // RETRO 👾 — styl arcade 8-bit
    ctx.save();
    // Siatka CRT
    ctx.strokeStyle='rgba(0,255,0,0.04)';ctx.lineWidth=1;
    for(let y=0;y<GROUND;y+=8){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}
    for(let x=0;x<W;x+=8){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,GROUND);ctx.stroke();}
    // Pikselowe "gwiazdy" (białe kwadraty)
    ctx.fillStyle='rgba(0,255,0,0.5)';
    for(const s of bgStars){
      ctx.fillRect(Math.floor(s.x/4)*4,Math.floor(s.y/4)*4,2,2);
    }
    // Scanlines CRT
    ctx.globalAlpha=0.08;
    ctx.fillStyle='#000';
    for(let y=0;y<GROUND;y+=4){ctx.fillRect(0,y+2,W,2);}
    ctx.globalAlpha=1;
    // Migające "INSERT COIN" w tle
    if(Math.floor(t*2)%2===0){
      ctx.fillStyle='rgba(0,255,0,0.04)';
      ctx.font=`bold ${TILE*0.5}px monospace`;
      ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('INSERT COIN',W/2,GROUND*0.2);
    }
    ctx.restore();
  } else if(lv.world===2){
    // ŚWIAT WODY — podwodny efekt z bąbelkami i kauztyką
    ctx.save();
    // Podwodna kaustyka (siatka świetlna)
    ctx.globalAlpha=0.06;
    for(let i=0;i<12;i++){
      const wx=((i*137+t*18)%W);
      const cg=ctx.createRadialGradient(wx,GROUND*0.5,0,wx,GROUND*0.5,TILE*3);
      cg.addColorStop(0,'rgba(0,180,255,1)');cg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=cg;ctx.beginPath();ctx.arc(wx,GROUND*0.5,TILE*3,0,Math.PI*2);ctx.fill();
    }
    ctx.globalAlpha=1;
    // Bąbelki unoszące się w górę
    ctx.fillStyle='rgba(150,230,255,0.35)';
    for(let i=0;i<18;i++){
      const bx=((i*97+levelProgress*0.4)%W);
      const by=GROUND*(0.9-(((t*0.4+i*0.7)%1.0)));
      const br=TILE*0.06+Math.sin(t*2+i)*TILE*0.03;
      ctx.beginPath();ctx.arc(bx,by,br,0,Math.PI*2);ctx.fill();
    }
    // Poziome fale świetlne
    ctx.globalAlpha=0.04;
    for(let i=0;i<4;i++){
      const wy=GROUND*(0.2+i*0.18)+Math.sin(t*0.8+i)*TILE*0.5;
      ctx.strokeStyle='rgba(100,220,255,1)';ctx.lineWidth=TILE*0.3;
      ctx.beginPath();
      for(let x=0;x<W;x+=8){
        const y=wy+Math.sin(x*0.02+t*1.5+i)*TILE*0.3;
        x===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
      }
      ctx.stroke();
    }
    ctx.globalAlpha=1;
    // Glony na dole
    ctx.fillStyle='rgba(0,150,60,0.5)';
    for(let i=0;i<10;i++){
      const gx=((i*173+levelProgress*0.3)%W);
      const gh=TILE*(0.8+Math.sin(t*1.2+i)*0.3);
      ctx.beginPath();
      ctx.moveTo(gx,GROUND);
      for(let s=0;s<8;s++){
        const sy=GROUND-gh*(s/8);
        const sx=gx+Math.sin(t*1.5+s*0.8+i)*TILE*0.25;
        ctx.lineTo(sx,sy);
      }
      ctx.lineWidth=3;ctx.strokeStyle='rgba(0,180,70,0.6)';ctx.stroke();
    }
    ctx.restore();
  }

  for(const s of bgStars){ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);ctx.fillStyle=`rgba(255,255,255,${0.25+s.alpha*0.5})`;ctx.fill();}

  if(currentLevel&&currentLevel.isCity) drawCity();

  ctx.fillStyle=theme.ground;ctx.fillRect(0,GROUND,W,H-GROUND);
  // W trybie retro — pikselowana linia podłogi
  if(currentLevel&&currentLevel.isRetro){
    ctx.fillStyle='#00ff00';
    for(let gx=0;gx<W;gx+=8){ctx.fillRect(gx,GROUND,6,6);}
    ctx.shadowBlur=0;
  } else {
    ctx.strokeStyle=theme.line;ctx.shadowColor=theme.line;ctx.shadowBlur=10;ctx.lineWidth=2;
    ctx.beginPath();ctx.moveTo(0,GROUND);ctx.lineTo(W,GROUND);ctx.stroke();ctx.shadowBlur=0;
  }

  ctx.strokeStyle='rgba(255,255,255,0.04)';ctx.lineWidth=1;
  for(let gx=(levelProgress*0.5)%TILE;gx<W;gx+=TILE){ctx.beginPath();ctx.moveTo(gx,GROUND);ctx.lineTo(gx,H);ctx.stroke();}

  // Sufit w trybie latania
  if(flyMode){
    ctx.fillStyle='rgba(0,200,255,0.12)';
    ctx.fillRect(0,0,W,GROUND);
    ctx.strokeStyle='#00ccff'; ctx.shadowColor='#00ccff'; ctx.shadowBlur=14; ctx.lineWidth=4;
    ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(W,0); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(0,GROUND-2); ctx.lineTo(W,GROUND-2); ctx.stroke();
    ctx.shadowBlur=0;
  }

  for(const p of platforms) drawPlatform(p);
  for(const orb of orbs) drawOrb(orb);
  // Rysuj kolce i platformy latania
  for(const fs of flySpikes){
    if(fs.isPlatform){
      ctx.save();
      ctx.fillStyle='#cc2200'; ctx.shadowColor='#ff3300'; ctx.shadowBlur=10;
      ctx.fillRect(fs.x,fs.y,fs.w,fs.h);
      // Białe obramowanie
      ctx.strokeStyle='rgba(255,255,255,0.95)';ctx.lineWidth=1.8;
      ctx.shadowColor='#ffffff';ctx.shadowBlur=10;
      ctx.strokeRect(fs.x+0.9,fs.y+0.9,fs.w-1.8,fs.h-1.8);
      ctx.fillStyle='rgba(255,100,0,0.5)';ctx.shadowBlur=0;
      ctx.font=`${fs.h*1.2}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('✕',fs.x+fs.w/2,fs.y+fs.h/2);
      ctx.restore();
    } else {
      ctx.save();
      ctx.beginPath();
      if(fs.fromTop){ctx.moveTo(fs.x+fs.w/2,fs.y+fs.h);ctx.lineTo(fs.x+fs.w,fs.y);ctx.lineTo(fs.x,fs.y);}
      else{ctx.moveTo(fs.x+fs.w/2,fs.y);ctx.lineTo(fs.x+fs.w,fs.y+fs.h);ctx.lineTo(fs.x,fs.y+fs.h);}
      ctx.closePath();
      ctx.fillStyle='#ff3030';ctx.shadowColor='#ff3030';ctx.shadowBlur=12;ctx.fill();
      ctx.strokeStyle='rgba(255,255,255,0.95)';ctx.lineWidth=1.5;
      ctx.shadowColor='#ffffff';ctx.shadowBlur=8;ctx.stroke();
      ctx.restore();
    }
  }

  const Q=QUALITY_SETTINGS[qualityMode]||QUALITY_SETTINGS.fast;

  if(Q.trail){
    for(let i=0;i<trail.length;i++){
      const alpha=(i/trail.length)*0.45,sz=(i/trail.length)*player.size*0.55;
      ctx.fillStyle=`rgba(64,192,240,${alpha})`;
      ctx.fillRect(trail[i].x-sz/2,trail[i].y-sz/2,sz,sz);
    }
  }

  for(const obs of obstacles){
    if(currentLevel&&currentLevel.isRetro){
      drawRetroObs(obs);
    } else if(obs.type==='spike'||obs.type==='spike-top') drawSpike(obs);
    else if(obs.type==='jumppad')     drawJumpPad(obs);
    else if(obs.type==='walkblock')   drawWalkBlock(obs);
    else if(obs.type==='spike-slide') drawSlidingSpike(obs);
    else if(obs.type==='spike-fall')  drawFallingSpike(obs);
    else drawBlock(obs);
  }
  for(const fp of flyPortals) drawFlyPortal(fp);
  if(state==='playing') drawPlayer();

  if(Q.particles){
    for(const p of particles){
      ctx.globalAlpha=p.life;ctx.fillStyle=p.color;
      if(Q.shadowBlur){ctx.shadowColor=p.color;ctx.shadowBlur=8*Q.shadowMult;}
      ctx.fillRect(p.x-p.size/2,p.y-p.size/2,p.size,p.size);
    }
  }
  ctx.globalAlpha=1;ctx.shadowBlur=0;

  // RTX
  if(Q.rtx && state==='playing') rtx_render();

  // Progress bar
  const effLen = currentLevel.custom ? currentLevel.customLength : (LEVEL_LENGTHS[currentLevel.id]||LEVEL_LENGTH);
  const pct=Math.min(1,levelProgress/effLen);
  // Przywróć transform przed UI (UI nie porusza się z kamerą)
  ctx.restore();
  ctx.fillStyle='rgba(255,255,255,0.07)';ctx.fillRect(0,H-6,W,6);
  const pgrd=ctx.createLinearGradient(0,0,W,0);
  pgrd.addColorStop(0,currentLevel.color);pgrd.addColorStop(1,currentLevel.shadow);
  ctx.fillStyle=pgrd;ctx.shadowColor=currentLevel.color;ctx.shadowBlur=6;
  ctx.fillRect(0,H-6,W*pct,6);ctx.shadowBlur=0;
}



// ===================== LEVEL EDITOR =====================
const ED = {
  canvas: null, ctx: null,
  tool: 'spike',
  tiles: [],        // {col, row, type}
  COLS: 150, ROWS: 12,
  scrollX: 0,
  painting: false,
  erasing: false,
};

function ed_init(){
  ED.canvas = document.getElementById('ed-canvas');
  ED.ctx = ED.canvas.getContext('2d');
  ED.canvas.addEventListener('mousedown', ed_mousedown);
  ED.canvas.addEventListener('mousemove', ed_mousemove);
  ED.canvas.addEventListener('mouseup',   ()=>{ ED.painting=false; });
  ED.canvas.addEventListener('wheel',     ed_wheel, {passive:false});
  ED.canvas.addEventListener('touchstart', ed_touchstart, {passive:false});
  ED.canvas.addEventListener('touchmove',  ed_touchmove,  {passive:false});
  ED.canvas.addEventListener('touchend',   ()=>{ ED.painting=false; });
  document.getElementById('ed-speed').addEventListener('input', function(){
    document.getElementById('ed-speed-val').textContent = this.value;
  });
  // Wypełnij selektor muzyki
  const sel=document.getElementById('ed-track');
  if(sel && sel.options.length===0){
    MUSIC_TRACKS.forEach((tr,i)=>{
      const opt=document.createElement('option');
      opt.value=i; opt.textContent=`${i+1}. ${tr.name} (${tr.bpm}BPM)`;
      sel.appendChild(opt);
    });
  }
}

function ed_previewTrack(){
  const idx=parseInt(document.getElementById('ed-track').value)||0;
  musicPlayGame(0, idx);
}

function ed_tileSize(){
  return Math.floor(ED.canvas.clientHeight / ED.ROWS);
}

function ed_resize(){
  ED.canvas.width  = ED.canvas.clientWidth;
  ED.canvas.height = ED.canvas.clientHeight;
}

function ed_open(){
  if(!ED.canvas) ed_init();
  ed_resize();
  document.getElementById('ed-screen').style.display='flex';
  document.getElementById('screen').style.display='none';
  ed_draw();
}

function ed_close(){
  document.getElementById('ed-screen').style.display='none';
  document.getElementById('screen').style.display='flex';
}

function ed_clear(){
  if(confirm('Wyczyścić cały poziom?')){ ED.tiles=[]; ed_draw(); }
}

function ed_setTool(t){
  ED.tool=t;
  document.querySelectorAll('.ed-tool-btn').forEach(b=>b.classList.remove('active'));
  const el=document.getElementById('edt-'+t);
  if(el) el.classList.add('active');
}

function ed_colRow(ex, ey){
  const ts=ed_tileSize();
  const col=Math.floor((ex+ED.scrollX)/ts);
  const row=Math.floor(ey/ts);
  return {col, row};
}

function ed_paint(ex, ey){
  const {col,row}=ed_colRow(ex,ey);
  if(col<0||col>=ED.COLS||row<0||row>=ED.ROWS) return;
  // remove existing tile at this position
  ED.tiles=ED.tiles.filter(t=>!(t.col===col&&t.row===row));
  if(ED.tool!=='erase'){
    ED.tiles.push({col,row,type:ED.tool});
  }
  ed_draw();
}

function ed_mousedown(e){
  ED.painting=true;
  const r=ED.canvas.getBoundingClientRect();
  ed_paint(e.clientX-r.left, e.clientY-r.top);
}
function ed_mousemove(e){
  if(!ED.painting) return;
  const r=ED.canvas.getBoundingClientRect();
  ed_paint(e.clientX-r.left, e.clientY-r.top);
}
function ed_touchstart(e){
  e.preventDefault(); ED.painting=true;
  const r=ED.canvas.getBoundingClientRect();
  ed_paint(e.touches[0].clientX-r.left, e.touches[0].clientY-r.top);
}
function ed_touchmove(e){
  e.preventDefault(); if(!ED.painting) return;
  const r=ED.canvas.getBoundingClientRect();
  ed_paint(e.touches[0].clientX-r.left, e.touches[0].clientY-r.top);
}
function ed_wheel(e){
  e.preventDefault();
  const ts=ed_tileSize();
  ED.scrollX=Math.max(0,Math.min(ED.scrollX+e.deltaY*0.5,(ED.COLS-1)*ts));
  ed_draw();
}

function ed_draw(){
  const c=ED.canvas, ctx=ED.ctx;
  const ts=ed_tileSize();
  c.width=c.clientWidth; c.height=c.clientHeight;
  const visibleCols=Math.ceil(c.width/ts)+1;
  const startCol=Math.floor(ED.scrollX/ts);

  // background
  ctx.fillStyle='#06060f'; ctx.fillRect(0,0,c.width,c.height);

  // strefa latania (jaśniejsza)
  ctx.fillStyle='rgba(0,100,200,0.07)';
  ctx.fillRect(0,0,c.width,(ED.ROWS-1)*ts);

  // ground line
  const groundY=(ED.ROWS-1)*ts;
  ctx.fillStyle='#1a1a2e'; ctx.fillRect(0,groundY,c.width,ts);
  ctx.strokeStyle='#3040a0'; ctx.lineWidth=2;
  ctx.beginPath(); ctx.moveTo(0,groundY); ctx.lineTo(c.width,groundY); ctx.stroke();

  // sufit
  ctx.strokeStyle='rgba(0,200,255,0.3)'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(0,ts); ctx.lineTo(c.width,ts); ctx.stroke();

  // etykiety
  ctx.font='11px monospace'; ctx.textBaseline='top';
  ctx.fillStyle='rgba(0,200,255,0.5)'; ctx.fillText('SUFIT (tryb latania)', 4, 2);
  ctx.fillStyle='rgba(100,120,255,0.5)'; ctx.fillText('ZIEMIA', 4, groundY+2);

  // grid
  ctx.strokeStyle='rgba(255,255,255,0.05)'; ctx.lineWidth=1;
  for(let col=startCol;col<=startCol+visibleCols;col++){
    const x=col*ts-ED.scrollX;
    ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,c.height); ctx.stroke();
  }
  for(let row=0;row<=ED.ROWS;row++){
    ctx.beginPath(); ctx.moveTo(0,row*ts); ctx.lineTo(c.width,row*ts); ctx.stroke();
  }

  // tiles
  const COLORS={spike:'#ff3030','spike-top':'#ff6060',block:'#9020d0','block-tall':'#b040f0',portal:'#00ccff',orb:'#e060ff',platform:'#30c060',jumppad:'#ffcc00',walkblock:'#5588ff','spike-slide':'#ff8844','spike-fall':'#ff2244'};
  for(const t of ED.tiles){
    const x=t.col*ts-ED.scrollX;
    const y=t.row*ts;
    if(x+ts<0||x>c.width) continue;
    ctx.save();
    ctx.fillStyle=COLORS[t.type]||'#888';
    ctx.shadowColor=ctx.fillStyle; ctx.shadowBlur=8;
    if(t.type==='spike'){
      ctx.beginPath();
      ctx.moveTo(x+ts/2,y+2); ctx.lineTo(x+ts-2,y+ts-2); ctx.lineTo(x+2,y+ts-2);
      ctx.closePath(); ctx.fill();
    } else if(t.type==='spike-top'){
      ctx.beginPath();
      ctx.moveTo(x+ts/2,y+ts-2); ctx.lineTo(x+ts-2,y+2); ctx.lineTo(x+2,y+2);
      ctx.closePath(); ctx.fill();
    } else if(t.type==='spike-slide'){
      // Podstawa + animowany kolec
      ctx.fillStyle='#555'; ctx.fillRect(x+1,y+ts*0.75,ts-2,ts*0.25);
      ctx.fillStyle='#ff8844'; ctx.shadowColor='#ff8844';
      ctx.beginPath();ctx.moveTo(x+ts/2,y+4);ctx.lineTo(x+ts-2,y+ts*0.75);ctx.lineTo(x+2,y+ts*0.75);ctx.closePath();ctx.fill();
      ctx.fillStyle='#fff';ctx.font=`${ts*0.4}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('⇅',x+ts/2,y+ts*0.4);
    } else if(t.type==='spike-fall'){
      // Kolec skierowany w dół (z sufitu)
      ctx.fillStyle='#ff2244'; ctx.shadowColor='#ff2244';
      ctx.beginPath();ctx.moveTo(x+ts/2,y+ts-2);ctx.lineTo(x+ts-2,y+2);ctx.lineTo(x+2,y+2);ctx.closePath();ctx.fill();
      ctx.fillStyle='rgba(255,80,80,0.3)';ctx.fillRect(x+ts*0.45,y-ts,ts*0.1,ts);
      ctx.fillStyle='#fff';ctx.font=`${ts*0.4}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('↓',x+ts/2,y+ts*0.5);
    } else if(t.type==='jumppad'){
      ctx.fillStyle='#ffcc00';ctx.shadowColor='#ffcc00';
      ctx.beginPath();ctx.roundRect(x+1,y+ts*0.5,ts-2,ts*0.5,4);ctx.fill();
      ctx.fillStyle='#fff';ctx.font=`${ts*0.5}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.shadowBlur=0;ctx.fillText('⬆',x+ts/2,y+ts*0.75);
      ctx.strokeStyle='rgba(255,255,180,0.8)';ctx.lineWidth=1.5;
      ctx.beginPath();ctx.roundRect(x+1,y+ts*0.5,ts-2,ts*0.5,4);ctx.stroke();
    } else if(t.type==='walkblock'){
      ctx.fillStyle='#5588ff';ctx.shadowColor='#5588ff';
      ctx.fillRect(x+1,y+1,ts-2,ts-2);
      ctx.fillStyle='rgba(180,210,255,0.3)';ctx.fillRect(x+2,y+2,ts-4,ts*0.3);
      ctx.strokeStyle='rgba(255,255,255,0.8)';ctx.lineWidth=1.5;ctx.shadowColor='#fff';ctx.shadowBlur=6;
      ctx.strokeRect(x+1,y+1,ts-2,ts-2);
      ctx.fillStyle='#fff';ctx.font=`${ts*0.5}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.shadowBlur=0;
      ctx.fillText('🦶',x+ts/2,y+ts/2);
    } else if(t.type==='portal'){
      ctx.strokeStyle='#00ccff'; ctx.lineWidth=3; ctx.shadowBlur=14;
      ctx.strokeRect(x+2,y+2,ts-4,ts*3);
      ctx.fillStyle='rgba(0,200,255,0.15)'; ctx.fillRect(x+2,y+2,ts-4,ts*3);
      ctx.fillStyle='#fff'; ctx.font=`${ts*0.6}px serif`;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText('✈',x+ts/2,y+ts*1.5);
    } else if(t.type==='orb'){
      ctx.beginPath(); ctx.arc(x+ts/2,y+ts/2,ts*0.4,0,Math.PI*2); ctx.fill();
    } else if(t.type==='platform'){
      ctx.fillStyle='#30c060'; ctx.shadowColor='#30c060'; ctx.shadowBlur=8;
      ctx.fillRect(x+1,y+ts*0.35,ts-2,ts*0.3);
      ctx.strokeStyle='rgba(255,255,255,0.8)';ctx.lineWidth=1;ctx.strokeRect(x+1,y+ts*0.35,ts-2,ts*0.3);
    } else if(t.type==='block-tall'){
      ctx.fillRect(x+1,y+1,ts-2,ts*2-2);
      ctx.strokeStyle='rgba(255,255,255,0.6)';ctx.lineWidth=1.5;ctx.shadowColor='#fff';ctx.shadowBlur=6;
      ctx.strokeRect(x+1,y+1,ts-2,ts*2-2);
    } else {
      ctx.fillRect(x+1,y+1,ts-2,ts-2);
      ctx.strokeStyle='rgba(255,255,255,0.6)';ctx.lineWidth=1.5;ctx.shadowColor='#fff';ctx.shadowBlur=6;
      ctx.strokeRect(x+1,y+1,ts-2,ts-2);
    }
    ctx.restore();
  }

  // scroll indicator
  const pct=ED.scrollX/((ED.COLS-1)*ts);
  ctx.fillStyle='rgba(255,255,255,0.1)'; ctx.fillRect(0,c.height-4,c.width,4);
  ctx.fillStyle='#f0c040'; ctx.fillRect(pct*c.width*0.9,c.height-4,c.width*0.1,4);
}

function ed_play(){
  const speedVal = parseFloat(document.getElementById('ed-speed').value)||4;
  const durationSec = parseFloat(document.getElementById('ed-duration').value)||30;
  const trackId = parseInt(document.getElementById('ed-track').value)||0;
  const customLength = durationSec * 60 * speedVal; // levelProgress += speed co klatkę
  // Build custom level from tiles
  const ts = ed_tileSize();
  const groundRow = ED.ROWS-1;
  const TILE_PX = H*0.09; // match game TILE size

  // Convert editor tiles to game objects
  const customObstacles=[], customPlatforms=[], customOrbs=[], customPortals=[];
  for(const t of ED.tiles){
    const gx = t.col * TILE_PX * 1.5 + W + 200;
    // mapuj wiersz edytora na Y w grze (row 0 = sufit, row ROWS-1 = podłoga)
    const gameY = (t.row / (ED.ROWS-1)) * GROUND;

    if(t.type==='spike'){
      customObstacles.push({x:gx, y:GROUND-TILE_PX, w:TILE_PX, h:TILE_PX, type:'spike'});
    } else if(t.type==='spike-top'){
      customObstacles.push({x:gx, y:gameY, w:TILE_PX, h:TILE_PX, type:'spike-top'});
    } else if(t.type==='block'){
      customObstacles.push({x:gx, y:gameY, w:TILE_PX, h:TILE_PX, type:'block'});
    } else if(t.type==='block-tall'){
      customObstacles.push({x:gx, y:gameY, w:TILE_PX, h:TILE_PX*2, type:'block'});
    } else if(t.type==='platform'){
      customPlatforms.push({x:gx, y:gameY, w:TILE_PX*2.5, h:TILE_PX*0.45});
    } else if(t.type==='orb'){
      customOrbs.push({x:gx, y:gameY, r:TILE_PX*0.42, collected:false, pulse:0});
    } else if(t.type==='portal'){
      customPortals.push({x:gx, y:0, w:TILE_PX*2, h:GROUND, pulse:0});
    } else if(t.type==='jumppad'){
      customObstacles.push({x:gx, y:GROUND-TILE_PX*0.55, w:TILE_PX*1.6, h:TILE_PX*0.55, type:'jumppad', pulse:0});
    } else if(t.type==='walkblock'){
      customObstacles.push({x:gx, y:gameY, w:TILE_PX*2.5, h:TILE_PX, type:'walkblock'});
    } else if(t.type==='spike-slide'){
      customObstacles.push({x:gx, y:GROUND-TILE_PX, w:TILE_PX, h:TILE_PX, type:'spike-slide', slideTimer:0, slideOut:true});
    } else if(t.type==='spike-fall'){
      customObstacles.push({x:gx, y:0, w:TILE_PX, h:TILE_PX, type:'spike-fall', vy:0, fallen:false});
    }
  }

  // Custom level config
  const customLevel = {
    id:99, name:'Własny', icon:'🎨',
    color:'#f0c040', shadow:'#c07000',
    speedBase: speedVal, speedGrow:0,
    gapMin:10, gapRand:8,
    obstacleOnly:false, lives:3,
    customLength, trackId,
    themes:[{sky1:'#04081a',sky2:'#0a1030',ground:'#0c1428',line:'#2040a0'}],
    fxInterval:0, fxType:null,
    unlocked:true, custom:true,
    customObstacles, customPlatforms, customOrbs, customPortals,
  };

  LEVELS[99] = customLevel;
  document.getElementById('ed-screen').style.display='none';
  startGame(99);
}

