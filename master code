function levelLoading_show(lvIdx, loadTime, onDone){
  const lv=LEVELS[lvIdx]||{icon:'🎮',name:'Poziom',color:'#30c060'};
  const el=document.getElementById('level-loading');
  const bar=document.getElementById('ll-bar');
  const step=document.getElementById('ll-step');
  const tip=document.getElementById('ll-tip');
  el.style.display='flex';
  document.getElementById('ll-icon').textContent=lv.icon||'🎮';
  document.getElementById('ll-name').textContent=lv.name;
  bar.style.background=lv.color||'#30c060';
  bar.style.boxShadow=`0 0 10px ${lv.color||'#30c060'}`;
  bar.style.width='0%';
  tip.textContent='💡 '+LEVEL_TIPS[Math.floor(Math.random()*LEVEL_TIPS.length)];

  const steps=[
    [10, '🗺 Inicjalizacja poziomu...'],
    [22, '🧱 Generowanie przeszkód...'],
    [35, '🌍 Budowanie tła...'],
    [47, '🎵 Ładowanie muzyki...'],
    [58, '⚙ Konfiguracja fizyki...'],
    [68, '🎨 Ładowanie skinów...'],
    [77, '💡 Inicjalizacja oświetlenia...'],
    [85, '🔧 Generowanie mapy...'],
    [93, '✅ Finalizacja...'],
    [100,'🚀 Start!'],
  ];
  let i=0;
  function next(){
