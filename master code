.toggle-btn{padding:5px 16px;border-radius:8px;border:2px solid #444;background:#222;color:#aaa;cursor:pointer;font-family:'Russo One',sans-serif;font-size:13px;transition:all 0.15s;}
.toggle-btn.active{background:rgba(48,192,96,0.2);border-color:#30c060;color:#80ff80;}
#screen h1{font-family:'Russo One',sans-serif;font-size:clamp(28px,6vw,58px);background:linear-gradient(135deg,#f0c040,#ff5030,#c030f0);-webkit-background-clip:text;-webkit-text-fill-color:transparent;text-align:center;margin-bottom:4px;animation:pulse 1.6s ease-in-out infinite;}
#screen .sub{color:#888;font-size:clamp(11px,2vw,14px);margin-bottom:10px;text-align:center;}
#screen .best{color:#f0c040;font-size:clamp(12px,2vw,18px);margin-bottom:10px;font-weight:700;}
#level-grid{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;align-items:center;max-width:640px;}
.page-arrow{
  background:rgba(255,255,255,0.08);border:2px solid rgba(255,255,255,0.2);
  border-radius:10px;color:#fff;font-size:22px;width:44px;height:44px;
  cursor:pointer;transition:all 0.15s;flex-shrink:0;
}
.page-arrow:hover:not(:disabled){background:rgba(255,255,255,0.18);transform:scale(1.1);}
.page-arrow:disabled{opacity:0.2;cursor:not-allowed;}
.lvl-btn{width:clamp(70px,18vw,110px);height:clamp(70px,18vw,110px);border:none;border-radius:12px;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;font-family:'Russo One',sans-serif;font-size:clamp(10px,2vw,13px);color:#fff;transition:transform 0.15s,box-shadow 0.15s;text-shadow:0 2px 4px rgba(0,0,0,0.6);}
.lvl-btn .icon{font-size:clamp(18px,4vw,28px);}
.lvl-btn .lname{font-size:clamp(9px,1.5vw,11px);opacity:0.85;}
@keyframes pulse{0%,100%{filter:brightness(1)}50%{filter:brightness(1.6)}}
.lvl-btn:hover{transform:scale(1.08);}
.lvl-btn.locked{opacity:0.35;cursor:not-allowed;filter:grayscale(0.7);}

/* Action button */
#action-btn{
  margin-top:22px;padding:13px 48px;
  font-family:'Russo One',sans-serif;font-size:20px;
  background:linear-gradient(135deg,#f0c040,#ff5030);
  border:none;border-radius:8px;color:#fff;cursor:pointer;
  box-shadow:0 0 28px rgba(240,150,40,0.45);
  transition:transform 0.1s,box-shadow 0.1s;
}
#action-btn:hover{transform:scale(1.05);box-shadow:0 0 48px rgba(240,150,40,0.7);}

/* Screen effect overlay for bonus level */
#fx-overlay{position:absolute;inset:0;pointer-events:none;z-index:12;opacity:0;transition:opacity 0.3s;}

/* Pause button */
#pause-btn{
  position:absolute;top:16px;left:50%;transform:translateX(-50%);
  width:44px;height:44px;border-radius:8px;
  background:rgba(255,255,255,0.12);
  border:2px solid rgba(255,255,255,0.25);
  color:#fff;font-size:18px;cursor:pointer;
  display:none;align-items:center;justify-content:center;
  z-index:11;transition:background 0.1s;
}
#pause-btn:hover{background:rgba(255,255,255,0.25);}
/* Pause overlay */
#pause-screen{
  position:absolute;inset:0;z-index:18;
