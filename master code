  if(bar){ setTimeout(()=>animEl(bar,'anim-fadeIn'),300); }
}

// Animacja przejścia do innego świata
function animWorldSwitch(worldName,color,cb){
  // Specjalny efekt przejścia między światami
  transOverlay.style.background=`radial-gradient(circle at 50% 50%, ${color}ee, #06060f)`;
  transOverlay.style.transition='opacity 0.25s';
  transOverlay.classList.add('active');

  // Tekst świata
  const wt=document.createElement('div');
  wt.style.cssText=`position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
    z-index:501;font-family:'Russo One',sans-serif;font-size:clamp(24px,6vw,48px);
    color:${color};text-align:center;text-shadow:0 0 30px ${color};
    animation:popIn 0.4s cubic-bezier(0.34,1.56,0.64,1) both;`;
  wt.innerHTML=`${worldName}<br><span style="font-size:0.5em;color:rgba(255,255,255,0.6);">Ładowanie...</span>`;
  document.body.appendChild(wt);

  setTimeout(()=>{
    wt.style.animation='fadeOut 0.3s ease forwards';
    setTimeout(()=>{
      wt.remove();
      if(cb) cb();
      setTimeout(()=>transOverlay.classList.remove('active'),100);
    },300);
  },800);
}

// Animacja wygranej
function animWin(){
  // Eksplozja cząsteczek (CSS)
  for(let i=0;i<20;i++){
    const p=document.createElement('div');
    const angle=Math.random()*360;
    const dist=80+Math.random()*120;
    const hue=Math.random()*360;
    p.style.cssText=`position:fixed;left:50%;top:50%;width:8px;height:8px;
      border-radius:50%;background:hsl(${hue},100%,60%);pointer-events:none;z-index:600;
      animation:ripple 0.8s ease-out forwards;
      transform:translate(${Math.cos(angle*Math.PI/180)*dist}px,${Math.sin(angle*Math.PI/180)*dist}px);`;
    document.body.appendChild(p);
    setTimeout(()=>p.remove(),800);
  }
}

