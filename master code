*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html{height:-webkit-fill-available;}
html,body{width:100%;height:100%;overflow:hidden;touch-action:none;-webkit-overflow-scrolling:touch;}
body{
  background:#06060f;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  height:100vh;
  height:-webkit-fill-available; /* iOS Safari fix */
  font-family:'Oxanium',sans-serif;
  overflow:hidden;
  /* Safe area dla iPhone z notchem */
  padding-top:env(safe-area-inset-top);
  padding-bottom:env(safe-area-inset-bottom);
  padding-left:env(safe-area-inset-left);
  padding-right:env(safe-area-inset-right);
}

/* ===== TELEFON — pionowo ===== */
@media (max-width:600px),(max-height:500px) and (orientation:landscape){
  #ui{padding:0 8px;font-size:12px!important;}
  .ui-box{font-size:13px!important;}
  #fps-counter{font-size:10px;top:3px;right:4px;}
  #coins-ui{font-size:13px!important;}
  .main-btn{font-size:13px!important;padding:11px 20px!important;}
  #main-title{font-size:clamp(30px,9vw,52px)!important;}
  .skin-card{width:78px!important;}
  .skin-card canvas{width:50px!important;height:50px!important;}
  #login-box{padding:18px 14px!important;gap:10px!important;}
  #screen h1{font-size:clamp(22px,7vw,40px)!important;}
  .lvl-btn{padding:8px 10px!important;font-size:11px!important;}
}

/* ===== TELEFON pionowo — specjalnie UI w grze ===== */
@media (max-width:600px) and (orientation:portrait){
  #ui{flex-wrap:wrap;gap:2px;top:8px;padding:0 6px;}
  .ui-box{font-size:11px!important;}
  #mobile-btn{width:60px!important;height:60px!important;font-size:26px!important;bottom:20px!important;right:20px!important;}
  #pause-btn{top:8px!important;right:8px!important;width:36px!important;height:36px!important;font-size:16px!important;}
}

/* ===== LAPTOP/DESKTOP — szeroki ===== */
@media (min-width:1024px){
  #login-box{max-width:420px;}
  .main-btn{font-size:17px!important;padding:15px 36px!important;}
  #main-title{font-size:clamp(52px,6vw,80px)!important;}
  .lvl-btn{padding:14px 18px!important;}
  #owner-panel>div{max-width:800px!important;}
}
/* LOGIN */
#login-screen{position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center;overflow:hidden;}
#login-bg{position:absolute;inset:0;background:linear-gradient(135deg,#04080f 0%,#0a1428 50%,#060c18 100%);}
#login-box{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:14px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:20px;padding:28px 28px;width:clamp(300px,92vw,440px);max-height:90vh;overflow-y:auto;backdrop-filter:blur(20px);}
#login-logo{font-family:'Russo One',sans-serif;font-size:clamp(28px,5vw,42px);color:#fff;text-align:center;line-height:1.1;text-shadow:0 0 30px rgba(48,192,96,0.5);}
#login-logo span{color:#30c060;text-shadow:0 0 20px #30c060;}
#login-cube-wrap{position:relative;width:44px;height:44px;}
#login-cube{width:38px;height:38px;background:#30c060;position:absolute;top:3px;left:3px;border-radius:6px;border:2px solid #80ff80;box-shadow:0 0 14px #30c060;animation:cube-spin 0.8s linear infinite;}
#login-tabs{display:flex;gap:0;width:100%;border-radius:10px;overflow:hidden;border:1px solid rgba(255,255,255,0.12);}
.login-tab{flex:1;padding:9px;font-family:'Russo One',sans-serif;font-size:13px;background:transparent;color:#666;border:none;cursor:pointer;transition:all 0.2s;}
.login-tab.active{background:rgba(48,192,96,0.2);color:#80ff80;}
#panel-login,#panel-register{width:100%;display:flex;flex-direction:column;gap:10px;}
.login-field{display:flex;flex-direction:column;gap:5px;width:100%;}
.login-field label{font-family:'Russo One',sans-serif;font-size:12px;color:#888;letter-spacing:0.5px;}
.login-field input{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:10px 14px;color:#fff;font-family:'Russo One',sans-serif;font-size:15px;outline:none;transition:border 0.2s;letter-spacing:2px;}
.login-field input:focus{border-color:#30c060;box-shadow:0 0 10px rgba(48,192,96,0.2);}
.login-btn{width:100%;padding:12px;font-family:'Russo One',sans-serif;font-size:15px;background:linear-gradient(135deg,rgba(48,192,96,0.25),rgba(32,128,64,0.15));border:2px solid #30c06088;border-radius:10px;color:#80ff80;cursor:pointer;transition:all 0.18s;letter-spacing:1px;}
.login-btn:hover{background:linear-gradient(135deg,rgba(48,192,96,0.45),rgba(32,128,64,0.3));transform:scale(1.02);}
.login-btn.green{background:linear-gradient(135deg,rgba(48,192,96,0.3),rgba(32,128,64,0.2));}
.login-msg{font-family:'Russo One',sans-serif;font-size:12px;text-align:center;min-height:16px;}
.login-msg.err{color:#ff6666;}
.login-msg.ok{color:#66ff88;}
#login-ver{font-size:11px;color:rgba(255,255,255,0.2);font-family:monospace;margin-top:4px;}

.troll-btn{padding:8px 12px;background:rgba(255,100,0,0.1);border:1px solid #ff660033;border-radius:8px;color:#ffaa66;cursor:pointer;font-family:'Russo One',sans-serif;font-size:12px;transition:all 0.15s;}
.troll-btn:hover{background:rgba(255,100,0,0.25);border-color:#ff6600;}
.se-fx-btn{padding:6px 12px;background:rgba(180,0,255,0.08);border:1px solid #aa00ff33;border-radius:7px;color:#aa66cc;cursor:pointer;font-family:'Russo One',sans-serif;font-size:11px;transition:all 0.15s;}
.se-fx-btn:hover{background:rgba(180,0,255,0.2);}
.se-fx-btn.active{background:rgba(180,0,255,0.3);border-color:#aa00ff;color:#cc88ff;}

/* LOADING */
#loading-screen{
  position:fixed;inset:0;z-index:999;background:#06060f;
  display:flex;align-items:center;justify-content:center;
  transition:opacity 0.6s ease;
}
#loading-screen.hidden{opacity:0;pointer-events:none;}
#loading-content{display:flex;flex-direction:column;align-items:center;gap:20px;}
#loading-logo{
  font-family:'Russo One',sans-serif;font-size:clamp(36px,7vw,64px);
  color:#fff;text-align:center;line-height:1.1;
  text-shadow:0 0 40px rgba(48,192,96,0.7);
}
#loading-logo span{color:#30c060;text-shadow:0 0 30px #30c060,0 0 60px #30ff80;}
#loading-cube-wrap{position:relative;width:70px;height:70px;}
#loading-cube{
  width:60px;height:60px;background:#30c060;
  position:absolute;top:5px;left:5px;
  border-radius:8px;border:3px solid #80ff80;
  box-shadow:0 0 20px #30c060;
  animation:cube-spin 0.8s linear infinite,cube-glow 1.2s ease-in-out infinite alternate;
}
@keyframes cube-spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes cube-glow{from{box-shadow:0 0 15px #30c060}to{box-shadow:0 0 40px #30ff80,0 0 60px #30c06088}}

/* ===== MEGA ANIMACJE ===== */

/* Wejście z góry */
@keyframes slideDown{from{transform:translateY(-60px);opacity:0}to{transform:translateY(0);opacity:1}}
/* Wejście z dołu */
@keyframes slideUp{from{transform:translateY(60px);opacity:0}to{transform:translateY(0);opacity:1}}
/* Wejście z lewej */
@keyframes slideLeft{from{transform:translateX(-80px);opacity:0}to{transform:translateX(0);opacity:1}}
/* Wejście z prawej */
@keyframes slideRight{from{transform:translateX(80px);opacity:0}to{transform:translateX(0);opacity:1}}
/* Pop — pojawienie się */
@keyframes popIn{0%{transform:scale(0) rotate(-10deg);opacity:0}70%{transform:scale(1.15) rotate(2deg)}100%{transform:scale(1) rotate(0deg);opacity:1}}
/* Fade in */
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
/* Fade out */
@keyframes fadeOut{from{opacity:1}to{opacity:0}}
/* Zoom in */
@keyframes zoomIn{from{transform:scale(0.5);opacity:0}to{transform:scale(1);opacity:1}}
/* Zoom out — wyjście */
@keyframes zoomOut{from{transform:scale(1);opacity:1}to{transform:scale(1.5);opacity:0}}
/* Shake */
@keyframes shakeAnim{0%,100%{transform:translateX(0)}20%{transform:translateX(-8px)}40%{transform:translateX(8px)}60%{transform:translateX(-5px)}80%{transform:translateX(5px)}}
/* Bounce */
@keyframes bounce{0%,100%{transform:translateY(0)}40%{transform:translateY(-18px)}60%{transform:translateY(-8px)}}
/* Spin in */
@keyframes spinIn{from{transform:rotate(-180deg) scale(0);opacity:0}to{transform:rotate(0) scale(1);opacity:1}}
/* Flip */
@keyframes flipIn{from{transform:rotateY(-90deg);opacity:0}to{transform:rotateY(0);opacity:1}}
/* Sway */
@keyframes sway{0%,100%{transform:rotate(-3deg)}50%{transform:rotate(3deg)}}
/* Float */
@keyframes floatAnim{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
/* Pulse glow */
@keyframes pulseGlow{0%,100%{box-shadow:0 0 10px currentColor}50%{box-shadow:0 0 30px currentColor,0 0 60px currentColor}}
/* Rainbow tekst */
@keyframes rainbowText{0%{filter:hue-rotate(0deg)}100%{filter:hue-rotate(360deg)}}
/* Wibrate */
@keyframes vibrate{0%,100%{transform:translate(0,0)}25%{transform:translate(-2px,2px)}50%{transform:translate(2px,-2px)}75%{transform:translate(-1px,1px)}}
/* Neon flicker */
@keyframes neonFlicker{0%,19%,21%,23%,25%,54%,56%,100%{opacity:1}20%,24%,55%{opacity:0.4}}
/* Wipe left */
@keyframes wipeLeft{from{clip-path:inset(0 100% 0 0)}to{clip-path:inset(0 0% 0 0)}}
/* Scale bounce */
@keyframes scaleBounce{0%{transform:scale(1)}30%{transform:scale(1.08)}60%{transform:scale(0.96)}100%{transform:scale(1)}}
/* Glow pulse */
@keyframes glowPulse{0%,100%{filter:brightness(1) drop-shadow(0 0 5px currentColor)}50%{filter:brightness(1.3) drop-shadow(0 0 20px currentColor)}}
/* Slide + fade */
@keyframes slideFade{from{transform:translateY(30px) scale(0.95);opacity:0}to{transform:translateY(0) scale(1);opacity:1}}
/* Ripple */
@keyframes ripple{0%{transform:scale(0);opacity:1}100%{transform:scale(3);opacity:0}}
/* Spin slow */
@keyframes spinSlow{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
/* Sweep */
@keyframes sweep{from{transform:translateX(-100%) skewX(-15deg)}to{transform:translateX(200%) skewX(-15deg)}}
/* Flash */
@keyframes flash{0%,50%,100%{opacity:1}25%,75%{opacity:0}}
/* Tada */
@keyframes tada{0%{transform:scale(1)}10%,20%{transform:scale(0.9) rotate(-3deg)}30%,50%,70%,90%{transform:scale(1.1) rotate(3deg)}40%,60%,80%{transform:scale(1.1) rotate(-3deg)}100%{transform:scale(1) rotate(0)}}

/* Klasy animacji */
.anim-slideDown{animation:slideDown 0.4s cubic-bezier(0.34,1.56,0.64,1) both}
.anim-slideUp{animation:slideUp 0.4s cubic-bezier(0.34,1.56,0.64,1) both}
.anim-slideLeft{animation:slideLeft 0.35s cubic-bezier(0.34,1.56,0.64,1) both}
.anim-slideRight{animation:slideRight 0.35s cubic-bezier(0.34,1.56,0.64,1) both}
.anim-popIn{animation:popIn 0.45s cubic-bezier(0.34,1.56,0.64,1) both}
.anim-fadeIn{animation:fadeIn 0.3s ease both}
.anim-zoomIn{animation:zoomIn 0.4s cubic-bezier(0.34,1.56,0.64,1) both}
.anim-spinIn{animation:spinIn 0.5s cubic-bezier(0.34,1.56,0.64,1) both}
.anim-flipIn{animation:flipIn 0.4s ease both}
.anim-slideFade{animation:slideFade 0.35s ease both}
.anim-bounce{animation:bounce 0.5s ease both}
.anim-tada{animation:tada 0.6s ease both}
.anim-shake{animation:shakeAnim 0.4s ease both}

/* Delay helpers */
.delay-1{animation-delay:0.05s}
.delay-2{animation-delay:0.1s}
.delay-3{animation-delay:0.15s}
.delay-4{animation-delay:0.2s}
.delay-5{animation-delay:0.25s}
.delay-6{animation-delay:0.3s}
.delay-7{animation-delay:0.35s}
.delay-8{animation-delay:0.4s}

/* Trwałe animacje */
.anim-float{animation:floatAnim 2.5s ease-in-out infinite}
.anim-sway{animation:sway 2s ease-in-out infinite}
.anim-pulse-glow{animation:pulseGlow 1.5s ease-in-out infinite}
.anim-rainbow{animation:rainbowText 3s linear infinite}
.anim-neon{animation:neonFlicker 2s linear infinite}
.anim-spin-slow{animation:spinSlow 8s linear infinite}

/* Przycisk główny — hover efekty */
.main-btn{transition:transform 0.18s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.18s,background 0.18s!important;}
.main-btn:hover{transform:scale(1.06) translateY(-2px)!important;}
.main-btn:active{transform:scale(0.96)!important;}

/* Przyciski poziomów */
.lvl-btn{transition:transform 0.2s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.2s!important;}
.lvl-btn:hover{transform:scale(1.08) translateY(-3px)!important;}
.lvl-btn:active{transform:scale(0.95)!important;}

/* Skin card */
.skin-card{transition:transform 0.2s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.2s,background 0.2s!important;}
.skin-card:hover{transform:scale(1.1) translateY(-4px)!important;box-shadow:0 8px 30px rgba(64,192,240,0.3)!important;}

/* Transition overlay */
#transition-overlay{
  position:fixed;inset:0;z-index:500;
  pointer-events:none;opacity:0;
  background:radial-gradient(circle,rgba(48,192,96,0.8),rgba(6,6,15,0.95));
  transition:opacity 0.3s;
}
#transition-overlay.active{opacity:1;pointer-events:all;}
#loading-bar-wrap{
  width:clamp(200px,40vw,320px);height:8px;
  background:rgba(255,255,255,0.08);border-radius:4px;overflow:hidden;
}
#loading-bar{
  height:100%;width:0%;background:linear-gradient(90deg,#30c060,#80ff80);
  border-radius:4px;transition:width 0.1s;
  box-shadow:0 0 8px #30c060;
}
#loading-text{
  font-family:'Russo One',sans-serif;font-size:14px;
  color:rgba(255,255,255,0.5);letter-spacing:1px;
}
/* FPS */
#fps-counter{
  position:fixed;top:6px;right:8px;z-index:500;
  font-family:monospace;font-size:12px;
  color:rgba(0,255,100,0.7);background:rgba(0,0,0,0.4);
  padding:2px 7px;border-radius:4px;pointer-events:none;
  border:1px solid rgba(0,255,100,0.2);
}
#ui{position:absolute;top:16px;left:0;right:0;display:flex;justify-content:space-between;align-items:center;padding:0 24px;pointer-events:none;z-index:10;}
.ui-box{font-family:'Russo One',sans-serif;font-size:20px;color:#fff;}
#level-name-ui{font-size:16px;opacity:0.8;}
canvas{display:block;}
#death-flash{position:absolute;inset:0;background:rgba(255,60,30,0.55);z-index:15;pointer-events:none;opacity:0;transition:opacity 0.08s;}

/* MENU SCREENS */
#screen{position:absolute;inset:0;z-index:20;display:none;flex-direction:column;align-items:center;justify-content:center;background:rgba(0,0,0,0.88);padding-bottom:90px;overflow-y:auto;}
/* GŁÓWNE MENU */
#main-menu{position:absolute;inset:0;z-index:25;display:flex;align-items:center;justify-content:center;overflow:hidden;}
#main-menu-bg{position:absolute;inset:0;background:linear-gradient(135deg,#04080f 0%,#0a1428 50%,#060c18 100%);}
#main-menu-content{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:18px;}
#main-title{font-family:'Russo One',sans-serif;font-size:clamp(42px,8vw,80px);color:#fff;text-align:center;line-height:1.1;margin:0 0 16px;text-shadow:0 0 40px rgba(48,192,96,0.6);}
#main-title span{color:#30c060;text-shadow:0 0 30px #30c060,0 0 60px #30ff80;}
#main-buttons{display:flex;flex-direction:column;gap:14px;width:clamp(220px,40vw,320px);}
.main-btn{
  font-family:'Russo One',sans-serif;font-size:clamp(14px,2.5vw,18px);
  padding:14px 32px;border-radius:12px;border:2px solid rgba(255,255,255,0.15);
  background:rgba(255,255,255,0.06);color:#fff;cursor:pointer;
  transition:all 0.18s;letter-spacing:1px;
  backdrop-filter:blur(8px);
}
.main-btn:hover{background:rgba(255,255,255,0.14);border-color:rgba(255,255,255,0.35);transform:scale(1.04);box-shadow:0 0 24px rgba(255,255,255,0.1);}
#btn-play{background:linear-gradient(135deg,rgba(48,192,96,0.3),rgba(32,128,64,0.2));border-color:#30c06088;color:#80ff80;text-shadow:0 0 12px #30c060;}
#btn-play:hover{background:linear-gradient(135deg,rgba(48,192,96,0.5),rgba(32,128,64,0.35));box-shadow:0 0 30px rgba(48,192,96,0.4);}
#btn-quit{background:linear-gradient(135deg,rgba(192,48,48,0.25),rgba(128,20,20,0.15));border-color:#c0303055;color:#ffaaaa;}
#btn-quit:hover{background:linear-gradient(135deg,rgba(220,60,60,0.4),rgba(160,30,30,0.3));box-shadow:0 0 24px rgba(200,48,48,0.35);}
#main-version{font-size:11px;color:rgba(255,255,255,0.25);font-family:monospace;margin-top:8px;}
#skin-grid-big{display:flex;gap:16px;flex-wrap:wrap;justify-content:center;max-width:680px;padding:0 16px;}
.skin-card{
  display:flex;flex-direction:column;align-items:center;gap:8px;
  background:rgba(255,255,255,0.06);border:2px solid rgba(255,255,255,0.12);
  border-radius:14px;padding:14px 12px;cursor:pointer;transition:all 0.18s;
  width:100px;
}
.skin-card:hover{background:rgba(255,255,255,0.14);transform:scale(1.06);}
.skin-card.selected{border-color:#40c0f0;background:rgba(64,192,240,0.18);box-shadow:0 0 20px rgba(64,192,240,0.3);}
.skin-card canvas{border-radius:6px;}
.skin-card span{color:#ccc;font-size:11px;font-family:'Russo One',sans-serif;text-align:center;}
/* USTAWIENIA */
#settings-screen{position:absolute;inset:0;z-index:26;display:none;flex-direction:column;align-items:center;justify-content:center;gap:16px;background:rgba(0,0,0,0.92);font-family:'Russo One',sans-serif;color:#fff;}
#settings-screen h2{font-size:28px;margin-bottom:8px;}
.setting-row{display:flex;align-items:center;gap:14px;width:clamp(280px,50vw,420px);justify-content:space-between;}
.setting-row label{color:#aaa;font-size:14px;min-width:140px;}
.setting-row input[type=range]{flex:1;accent-color:#30c060;}
