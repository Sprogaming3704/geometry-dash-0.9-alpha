// Wykrycie urządzenia
const isMobile=()=>window.innerWidth<=600||('ontouchstart' in window&&window.innerWidth<1024);

let canvasScale=1.0; // domyślnie 100% jak wcześniej

function applyResolution(val){
  canvasScale=parseFloat(val);
  const descs={
    '1.0':'🔲 Pełna rozdzielczość — najlepsza jakość, może lagować',
    '0.75':'📺 Wysoka rozdzielczość — dobra jakość',
    '0.5':'⚡ Średnia — dobry balans wydajności',
    '0.35':'🔋 Niska rozdzielczość — płynna na słabych urządzeniach',
    '0.25':'💨 Bardzo niska — maksymalna płynność, mniej ostra',
  };
  const d=document.getElementById('res-desc');
  if(d) d.textContent=descs[val]||'';
  onResize();
}

function resizeCanvas(){
  // visualViewport naprawia problem z iOS Safari (pasek adresu chowa się/pojawia)
  const vp=window.visualViewport||window;
  const w=Math.floor(vp.width||window.innerWidth);
  const h=Math.floor(vp.height||window.innerHeight);
  // CSS size = pełny ekran
  canvas.style.width=w+'px';
  canvas.style.height=h+'px';
  // Pikselowy rozmiar = pomniejszony dla wydajności
  canvas.width=Math.round(w*canvasScale);
  canvas.height=Math.round(h*canvasScale);
  ctx.imageSmoothingEnabled=canvasScale<1.0;
  ctx.imageSmoothingQuality=canvasScale>=0.75?'high':canvasScale>=0.5?'medium':'low';
}

// iOS visualViewport resize (chowanie/pokazywanie paska Safari)
if(window.visualViewport){
  window.visualViewport.addEventListener('resize',()=>{onResize();applyResponsiveLayout();});
  window.visualViewport.addEventListener('scroll',()=>{
    canvas.style.top=(window.visualViewport.offsetTop||0)+'px';
  });
}
resizeCanvas();

// Wymiary dynamiczne — zawsze aktualne
let W=canvas.width;
let H=canvas.height;
let GROUND=H*0.72;
let TILE=H*0.09;

function onResize(){
  resizeCanvas();
  // W, H = fizyczne piksele canvasa (po skali)
  W=canvas.width; H=canvas.height;
  GROUND=H*0.72; TILE=H*0.09;
  generateStars();
}
window.addEventListener('resize', ()=>{ onResize(); });
window.addEventListener('orientationchange',()=>{ setTimeout(onResize,300); });
