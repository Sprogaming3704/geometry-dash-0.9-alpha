  el.textContent=coins===Infinity?'🪙 ∞':`🪙 ${coins}`;
}

// ===================== SYSTEM ANIMACJI =====================

// Główna funkcja animacji elementu
function anim(el, animName, duration=400, delay=0){
  if(!el) return Promise.resolve();
  return new Promise(res=>{
    el.style.animation='none';
    el.offsetHeight; // reflow
    el.style.animation=`${animName} ${duration}ms cubic-bezier(0.34,1.56,0.64,1) ${delay}ms both`;
    setTimeout(res, duration+delay);
  });
}

// Animuj dzieci po kolei (stagger)
function animStagger(parent, animName, duration=350, staggerMs=60){
  if(!parent) return Promise.resolve();
  const children=[...parent.children];
  children.forEach((ch,i)=>{
    ch.style.animation='none';
    ch.offsetHeight;
    ch.style.animation=`${animName} ${duration}ms cubic-bezier(0.34,1.56,0.64,1) ${i*staggerMs}ms both`;
  });
  return new Promise(res=>setTimeout(res, duration+children.length*staggerMs));
}

// Przejście między ekranami z efektem
function screenOut(el, animName='fadeOut', duration=250){
  if(!el||el.style.display==='none') return Promise.resolve();
  return new Promise(res=>{
    el.style.animation=`${animName} ${duration}ms ease forwards`;
    setTimeout(()=>{ el.style.display='none'; el.style.animation=''; res(); }, duration);
  });
}

function screenIn(el, animName='fadeIn', duration=350, displayType='flex'){
  if(!el) return Promise.resolve();
  el.style.display=displayType;
  el.style.animation='none';
  el.offsetHeight;
  el.style.animation=`${animName} ${duration}ms cubic-bezier(0.34,1.56,0.64,1) both`;
  return new Promise(res=>setTimeout(res, duration));
}

// Ripple efekt na przycisku
function ripple(btn, e){
  const r=document.createElement('span');
  const rect=btn.getBoundingClientRect();
  const size=Math.max(rect.width,rect.height);
  r.style.cssText=`position:absolute;width:${size}px;height:${size}px;border-radius:50%;background:rgba(255,255,255,0.3);transform:scale(0);left:${(e?e.clientX:rect.left+rect.width/2)-rect.left-size/2}px;top:${(e?e.clientY:rect.top+rect.height/2)-rect.top-size/2}px;animation:ripple 0.6s ease forwards;pointer-events:none;`;
  btn.style.position='relative';btn.style.overflow='hidden';
  btn.appendChild(r);
  setTimeout(()=>r.remove(),700);
}

// Dodaj ripple do wszystkich przycisków
document.addEventListener('click',e=>{
  const btn=e.target.closest('button,.main-btn,.lvl-btn');
  if(btn) ripple(btn,e);
},{passive:true});

// Flash ekranu (np. przy śmierci)
function flashScreen(color='#ff0000', duration=300){
  const f=document.createElement('div');
  f.style.cssText=`position:fixed;inset:0;z-index:9999;background:${color};pointer-events:none;animation:fadeOut ${duration}ms ease forwards`;
  document.body.appendChild(f);
  setTimeout(()=>f.remove(),duration);
}

// Shake element
function shakeEl(el, intensity=8, duration=500){
  if(!el) return;
  const kf=[
    {transform:'translateX(0)'},
    {transform:`translateX(-${intensity}px)`},
    {transform:`translateX(${intensity}px)`},
    {transform:`translateX(-${intensity*0.6}px)`},
    {transform:`translateX(${intensity*0.6}px)`},
    {transform:'translateX(0)'},
  ];
  el.animate(kf,{duration,easing:'ease-in-out'});
}

// Bounce element
function bounceEl(el){
  if(!el) return;
  el.animate([
    {transform:'scale(1)'},{transform:'scale(1.15)'},{transform:'scale(0.95)'},{transform:'scale(1)'}
  ],{duration:400,easing:'cubic-bezier(0.34,1.56,0.64,1)'});
}

// Slide + fade przejście między ekranami
async function transitionTo(hideEl, showEl, direction='right'){
  const outAnims={right:'slideLeft',left:'slideRight',up:'slideDown',down:'slideUp'};
  const inAnims={right:'slideRight',left:'slideLeft',up:'slideUp',down:'slideDown'};
  await screenOut(hideEl, outAnims[direction]||'fadeOut', 220);
  const displayType=showEl?.tagName==='DIV'?
    (showEl.style.getPropertyValue('display')||'flex'):'flex';
  await screenIn(showEl, inAnims[direction]||'slideRight', 380, displayType);
}

// Animuj liczby (count up)
function animCounter(el, from, to, duration=800){
  if(!el) return;
  const start=performance.now();
  function step(now){
    const t=Math.min((now-start)/duration,1);
    const ease=1-Math.pow(1-t,3);
    el.textContent=Math.round(from+(to-from)*ease);
    if(t<1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

// Cząsteczki przy sukcesie (konfetti)
function spawnConfetti(x, y, count=20){
  for(let i=0;i<count;i++){
    const p=document.createElement('div');
    const hue=Math.random()*360;
    const size=6+Math.random()*8;
    p.style.cssText=`position:fixed;left:${x}px;top:${y}px;width:${size}px;height:${size}px;background:hsl(${hue},100%,60%);border-radius:${Math.random()>0.5?'50%':'2px'};pointer-events:none;z-index:9998;`;
    document.body.appendChild(p);
    const angle=Math.random()*Math.PI*2;
    const speed=80+Math.random()*120;
    const vx=Math.cos(angle)*speed, vy=Math.sin(angle)*speed-60;
    p.animate([
      {transform:`translate(0,0) rotate(0deg)`,opacity:1},
      {transform:`translate(${vx}px,${vy+200}px) rotate(${360+Math.random()*360}deg)`,opacity:0}
    ],{duration:800+Math.random()*400,easing:'cubic-bezier(0.25,0.46,0.45,0.94)',fill:'forwards'});
    setTimeout(()=>p.remove(),1300);
  }
}

