let cityBuildings=[], cityCars=[], cityNeons=[], cityPeople=[], cityAdTexts=[];
const AD_TEXTS=['PIZZA 🍕','SALE 50%','HOT DOG','CASINO 🎰','TAXI 🚕','SKLEP','PARKING','BAR 🍺','HOTEL','ATM 💰','GYM 💪','NEWS','COFFEE ☕','FOTO 📸','DISCO 🕺'];
const CAR_EMOJIS=['🚗','🚕','🚙','🚌','🚎','🏎️','🚓','🚑','🚒','🚐','🛻'];
const CAR_COLORS=['#ff2020','#ffcc00','#20aaff','#ff6600','#aa20ff','#20ff88','#ffffff','#ff20aa'];

function cityInit(){
  cityBuildings=[];
  cityCars=[];
  cityNeons=[];
  cityPeople=[];
  cityAdTexts=[];
  // Generuj budynki w tle
  for(let x=0;x<W*4;x+=TILE*(1.5+Math.random()*2)){
    const bh=TILE*(3+Math.random()*8);
    const bw=TILE*(1.2+Math.random()*2.5);
    cityBuildings.push({
      x, bw, bh,
      color:`hsl(${200+Math.random()*40},${10+Math.random()*20}%,${8+Math.random()*12}%)`,
      windows:[], layer: Math.random()<0.4?0:1,
      neonColor:`hsl(${Math.random()*360},100%,60%)`,
      hasSign: Math.random()<0.5,
      signText: AD_TEXTS[Math.floor(Math.random()*AD_TEXTS.length)],
    });
    // okna
    const rows=Math.floor(bh/TILE*0.8), cols=Math.floor(bw/TILE*0.7)+1;
    for(let r=0;r<rows;r++) for(let c=0;c<cols;c++)
      if(Math.random()<0.65) cityBuildings[cityBuildings.length-1].windows.push({r,c,on:Math.random()<0.7});
  }
  // Neony latające po niebie
  for(let i=0;i<12;i++){
    cityNeons.push({
      x:Math.random()*W*3, y:TILE*(0.5+Math.random()*4),
      text:AD_TEXTS[Math.floor(Math.random()*AD_TEXTS.length)],
      color:`hsl(${Math.random()*360},100%,65%)`,
      speed:0.3+Math.random()*0.8, size:14+Math.random()*20,
      blink:Math.random()*Math.PI*2,
    });
  }
  // Ludzie na chodniku
  for(let i=0;i<20;i++){
    cityPeople.push({
      x:Math.random()*W*3, speed:0.4+Math.random()*1.2,
      emoji:['🚶','🏃','👮','🧑','👩','👴','🧒','🕴️'][Math.floor(Math.random()*8)],
      dir: Math.random()<0.3?1:-1,
    });
  }
  // Samochody — różne pasy
  for(let i=0;i<18;i++) spawnCityCar();
}

function spawnCityCar(){
  const lane=Math.floor(Math.random()*3); // 0=pod graczem, 1=środek, 2=daleko (szybszy)
  const dir=Math.random()<0.6?1:-1;
  cityCars.push({
    x: dir>0 ? -TILE*3-Math.random()*W*2 : W+TILE*3+Math.random()*W*2,
    lane, dir,
    speed:(1.5+Math.random()*4)*(lane===2?1.8:1)*dir,
    color: CAR_COLORS[Math.floor(Math.random()*CAR_COLORS.length)],
    emoji: CAR_EMOJIS[Math.floor(Math.random()*CAR_EMOJIS.length)],
    w:TILE*(1.4+Math.random()*0.8), h:TILE*0.55,
    honk: Math.random()<0.15, // czy trąbi
    lights: Math.random()<0.5,
  });
}

function cityUpdate(){
  if(!currentLevel.isCity) return;
  const t=Date.now()/1000;
  // Budynki scrollują wolniej (paralax)
  for(const b of cityBuildings) b.x-=speed*0.3;
  // Neony
  for(const n of cityNeons){
    n.x-=n.speed;
    if(n.x<-200) n.x=W+200;
    n.blink+=0.08;
  }
  // Ludzie
  for(const p of cityPeople){
    p.x-=speed*0.5-p.speed*p.dir*0.3;
    if(p.x<-50) p.x=W+50;
    if(p.x>W+50) p.x=-50;
  }
  // Samochody — więcej
  for(const c of cityCars){
    c.x+=c.speed;
    if(c.dir>0&&c.x>W+TILE*4){ c.x=-TILE*4; c.speed=Math.abs(c.speed); }
    if(c.dir<0&&c.x<-TILE*4){ c.x=W+TILE*4; c.speed=-Math.abs(c.speed); }
  }
  if(cityCars.length<30) spawnCityCar();
  // Migające okna
  if(Math.random()<0.02){
    const b=cityBuildings[Math.floor(Math.random()*cityBuildings.length)];
    if(b&&b.windows.length>0){
      const w=b.windows[Math.floor(Math.random()*b.windows.length)];
      w.on=!w.on;
    }
  }
  // Płynne trzęsienie ekranu — sinusoidalne
  const shakeAmp = 1.5 + Math.sin(t*7)*0.8;
  shakeX = Math.sin(t*23)*shakeAmp + Math.sin(t*17)*shakeAmp*0.5;
  shakeY = Math.cos(t*19)*shakeAmp*0.6 + Math.sin(t*13)*shakeAmp*0.3;
  canvas.style.transform = `translate(${shakeX.toFixed(2)}px,${shakeY.toFixed(2)}px)`;
}

function drawCity(){
  if(!currentLevel||!currentLevel.isCity) return;
  const t=Date.now()/1000;

  // Budynki w tle (głębszy paralaks)
  for(const b of cityBuildings){
    const by=GROUND-b.bh;
    if(b.x+b.bw<-10||b.x>W+10) continue;
    ctx.save();
    // Bryła budynku
    ctx.fillStyle=b.color;
    ctx.fillRect(b.x,by,b.bw,b.bh);
    // Lekki zarys
    ctx.strokeStyle='rgba(255,200,100,0.12)';ctx.lineWidth=1;
    ctx.strokeRect(b.x,by,b.bw,b.bh);
    // Okna
    const ww=b.bw*0.22, wh=TILE*0.28;
    const cols=Math.max(1,Math.floor(b.bw/(ww*1.6)));
    const rows=Math.max(1,Math.floor(b.bh/(wh*1.8)));
    for(const win of b.windows){
      if(win.r>=rows||win.c>=cols) continue;
      const wx=b.x+win.c*(b.bw/(cols+0.5))+ww*0.4;
      const wy=by+win.r*(b.bh/(rows+0.3))+wh*0.5;
      if(win.on){
        const wc=`hsl(${40+Math.random()*20},80%,${60+Math.random()*20}%)`;
        ctx.fillStyle=wc; ctx.shadowColor=wc; ctx.shadowBlur=6;
      } else {
        ctx.fillStyle='rgba(30,30,50,0.8)'; ctx.shadowBlur=0;
      }
      ctx.fillRect(wx,wy,ww,wh);
    }
    ctx.shadowBlur=0;
    // Neon szyld na budynku
    if(b.hasSign){
      const alpha=0.7+Math.sin(t*3+b.x)*0.3;
      ctx.fillStyle=b.neonColor.replace(')',`,${alpha})`).replace('hsl','hsla');
      ctx.shadowColor=b.neonColor; ctx.shadowBlur=12;
      ctx.font=`bold ${TILE*0.38}px monospace`;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText(b.signText, b.x+b.bw/2, by+TILE*0.6);
      ctx.shadowBlur=0;
    }
    ctx.restore();
  }

  // Chodnik (pas między budynkami a ziemią)
  ctx.fillStyle='#222222';
  ctx.fillRect(0,GROUND-TILE*0.3,W,TILE*0.3);
  ctx.fillStyle='rgba(255,255,255,0.06)';
  const dashW=TILE*1.2, gap=TILE*0.8;
  for(let x=(levelProgress*0.4)%(dashW+gap);x<W;x+=dashW+gap){
    ctx.fillRect(x,GROUND-TILE*0.18,dashW,TILE*0.06);
  }

  // Latarnie
  for(let lx=TILE*4-(levelProgress*0.5)%(TILE*5);lx<W;lx+=TILE*5){
    ctx.save();
    ctx.strokeStyle='#888';ctx.lineWidth=3;
    ctx.beginPath();ctx.moveTo(lx,GROUND-TILE*0.3);ctx.lineTo(lx,GROUND-TILE*2.5);
    ctx.lineTo(lx+TILE*0.4,GROUND-TILE*2.5);ctx.stroke();
    ctx.fillStyle='rgba(255,240,180,0.9)';ctx.shadowColor='#ffee88';ctx.shadowBlur=20;
    ctx.beginPath();ctx.arc(lx+TILE*0.4,GROUND-TILE*2.5,TILE*0.12,0,Math.PI*2);ctx.fill();
    ctx.restore();
  }

  // Ludzie na chodniku
  for(const p of cityPeople){
    ctx.save();
    ctx.font=`${TILE*0.5}px serif`;
    ctx.textAlign='center';ctx.textBaseline='bottom';
    if(p.dir<0){ ctx.scale(-1,1); ctx.fillText(p.emoji,-p.x,GROUND-TILE*0.3); }
    else ctx.fillText(p.emoji,p.x,GROUND-TILE*0.3);
    ctx.restore();
  }

  // Samochody w tle — jadą za budynkami ale przed graczem
  // Dwa pasy tła: dalszy (mały, wysoko) i bliższy (większy, nisko)
  const bgLanes=[
    {y: GROUND*0.78, scale:0.45, alpha:0.7},  // daleki pas
    {y: GROUND*0.88, scale:0.65, alpha:0.85}, // środkowy pas
    {y: GROUND*0.97, scale:0.85, alpha:1.0},  // bliski pas (tuż nad ziemią)
  ];
  for(const c of cityCars){
    if(c.x+c.w*2<-5||c.x>W+5) continue;
    const lane=bgLanes[c.lane]||bgLanes[0];
    const cy=lane.y - c.h*lane.scale;
    const cw=c.w*lane.scale, ch=c.h*lane.scale;
    ctx.save();
    ctx.globalAlpha=lane.alpha;

    // Wiązka świateł przednich (stożek)
    const headX = c.dir>0 ? c.x+cw : c.x;
    const lightDir = c.dir>0 ? 1 : -1;
    const lightGrad=ctx.createLinearGradient(headX, cy+ch/2, headX+lightDir*TILE*3, cy+ch/2);
    lightGrad.addColorStop(0,'rgba(255,255,180,0.55)');
    lightGrad.addColorStop(1,'rgba(255,255,100,0)');
    ctx.beginPath();
    ctx.moveTo(headX, cy+ch*0.2);
    ctx.lineTo(headX+lightDir*TILE*3.5, cy-ch*0.3);
    ctx.lineTo(headX+lightDir*TILE*3.5, cy+ch*1.3);
    ctx.closePath();
    ctx.fillStyle=lightGrad;
    ctx.fill();

    // Światła tylne (czerwona poświata)
    const tailX = c.dir>0 ? c.x : c.x+cw;
    const tailGrad=ctx.createRadialGradient(tailX,cy+ch/2,0,tailX,cy+ch/2,TILE*0.8);
    tailGrad.addColorStop(0,'rgba(255,30,0,0.6)');
    tailGrad.addColorStop(1,'rgba(255,0,0,0)');
    ctx.fillStyle=tailGrad;
    ctx.fillRect(tailX-TILE*0.8,cy-ch*0.2,TILE*1.6,ch*1.4);

    // Karoseria
    ctx.fillStyle=c.color; ctx.shadowColor=c.color; ctx.shadowBlur=6*lane.scale;
    ctx.fillRect(c.x, cy, cw, ch);
    ctx.shadowBlur=0;

    // Emoji
    ctx.font=`${ch*1.4}px serif`;
    ctx.textAlign='center'; ctx.textBaseline='middle';
    if(c.dir<0){ctx.scale(-1,1); ctx.fillText(c.emoji,-(c.x+cw/2),cy+ch/2);}
    else ctx.fillText(c.emoji, c.x+cw/2, cy+ch/2);

    // Trąbienie
    if(c.honk&&Math.random()<0.004){
      ctx.font=`${TILE*0.35}px serif`; ctx.textBaseline='bottom';
      ctx.fillText('📯', c.x+cw/2, cy);
    }
    ctx.restore();
  }

  // Neony latające w tle
  for(const n of cityNeons){
    const alpha=0.5+Math.sin(n.blink)*0.5;
    ctx.save();
    ctx.font=`bold ${n.size}px monospace`;
    ctx.fillStyle=n.color.replace('hsl','hsla').replace(')',`,${alpha*0.7})`);
    ctx.shadowColor=n.color; ctx.shadowBlur=18*alpha;
    ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(n.text,n.x,n.y);
    ctx.restore();
  }

  // Efekt deszczu
  ctx.save();
  ctx.strokeStyle='rgba(180,200,255,0.18)';ctx.lineWidth=1;
  for(let i=0;i<30;i++){
    const rx=((i*137+levelProgress*2)%W);
    const ry=((i*97+levelProgress*3)%(GROUND));
    ctx.beginPath();ctx.moveTo(rx,ry);ctx.lineTo(rx-2,ry+TILE*0.3);ctx.stroke();
  }
  ctx.restore();
}

