  normal: {label:'',hp:1,speedMult:1.0,color:null,size:1.0,emoji:''},
  fast:   {label:'⚡',hp:1,speedMult:1.8,color:'#ffee00',size:0.85,emoji:'⚡'},
  tank:   {label:'🛡️',hp:1,speedMult:0.6,color:'#888888',size:1.2,emoji:'🛡️'},
  armored:{label:'🔒',hp:2,speedMult:0.9,color:'#cc8800',size:1.1,emoji:'🔒'}, // 2 trafienia
  ghost:  {label:'👻',hp:1,speedMult:1.4,color:'rgba(200,200,255,0.5)',size:1.0,emoji:'👻'},
};

let SN={
  canvas:null,ctx:null,active:false,
  bots:[],scope:{x:0,y:0},
  kills:0,        // łączne zabójstwa
  wave:1,         // numer fali
  waveKills:0,    // zabójstwa w tej fali
  waveSize:5,     // ile botów w tej fali
  waveDone:0,     // ile botów fali zabito
  waveActive:false,
  time:0,result:null,shots:[],bgScroll:0,
};

const SN_LANE_COUNT=5;
const SN_TOTAL_WAVES=20; // fal do wygrania

function sniper_botType(wave){
  // Im wyższa fala tym więcej specjalnych typów
  if(wave>30) return Math.random()<0.4?'armored':Math.random()<0.5?'fast':'normal';
  if(wave>20) return Math.random()<0.3?'armored':Math.random()<0.4?'fast':Math.random()<0.2?'ghost':'normal';
  if(wave>15) return Math.random()<0.2?'fast':Math.random()<0.15?'ghost':Math.random()<0.1?'tank':'normal';
  if(wave>8)  return Math.random()<0.15?'fast':Math.random()<0.1?'tank':'normal';
  if(wave>3)  return Math.random()<0.1?'fast':'normal';
  return 'normal';
}

function sniper_open(){
  document.getElementById('sniper-screen').style.display='block';
  SN.canvas=document.getElementById('sniper-canvas');
  SN.canvas.width=window.innerWidth;
  SN.canvas.height=window.innerHeight;
  SN.ctx=SN.canvas.getContext('2d');
  SN.scope={x:SN.canvas.width/2,y:SN.canvas.height/2};
  sniper_restart();
  SN.canvas.onmousemove=e=>{if(!SN.result){SN.scope.x=e.clientX;SN.scope.y=e.clientY;}};
  SN.canvas.ontouchmove=e=>{e.preventDefault();if(!SN.result){SN.scope.x=e.touches[0].clientX;SN.scope.y=e.touches[0].clientY;}};
  SN.canvas.onclick=e=>{if(!SN.result)sniper_shoot(e.clientX,e.clientY);};
  document.addEventListener('keydown',sniper_keydown);
  sniper_loop();
}

function sniper_close(){
  SN.active=false;
  document.getElementById('sniper-screen').style.display='none';
  document.getElementById('pause-btn').style.display='none';
  document.removeEventListener('keydown',sniper_keydown);
  showMenu();
}

function sniper_keydown(e){
  const step=18;
  if(e.key==='ArrowLeft'){e.preventDefault();SN.scope.x=Math.max(0,SN.scope.x-step);}
  if(e.key==='ArrowRight'){e.preventDefault();SN.scope.x=Math.min(SN.canvas.width,SN.scope.x+step);}
  if(e.key==='ArrowUp'){e.preventDefault();SN.scope.y=Math.max(0,SN.scope.y-step);}
  if(e.key==='ArrowDown'){e.preventDefault();SN.scope.y=Math.min(SN.canvas.height,SN.scope.y+step);}
  if(e.key===' '||e.key==='Enter'){e.preventDefault();if(!SN.result)sniper_shoot(SN.scope.x,SN.scope.y);}
}

function sniper_restart(){
  SN.active=true;SN.kills=0;SN.wave=1;SN.waveKills=0;SN.waveDone=0;
  SN.waveActive=false;SN.time=0;SN.result=null;SN.shots=[];SN.bgScroll=0;SN.bots=[];
  document.getElementById('sniper-result').style.display='none';
  document.getElementById('sniper-kills').textContent='0';
  document.getElementById('sniper-bot-level').textContent='FALA 1';
  document.getElementById('sniper-timer').textContent='0.0s';
  sniper_startWave();
}

function sniper_waveSize(wave){
  return Math.min(20, 3+Math.floor(wave*1.2)); // 3 boty na fali 1, do 20
}

function sniper_startWave(){
  SN.waveActive=true;
  SN.waveDone=0;
  SN.waveSize=sniper_waveSize(SN.wave);
  SN.bots=[];
  const usedNames=new Set();
  const count=Math.min(SN.waveSize, SN_LANE_COUNT);
  for(let i=0;i<count;i++){
    let ni=Math.floor(Math.random()*BOT_NAMES.length);
    while(usedNames.has(ni)) ni=(ni+1)%BOT_NAMES.length;
    usedNames.add(ni);
    const type=sniper_botType(SN.wave);
    const td=BOT_TYPES[type];
    SN.bots.push({
      name:BOT_NAMES[ni], lane:i,
      progress:Math.random()*0.05,
      speed:(0.0005+Math.random()*0.0004)*(1+SN.wave*0.08)*td.speedMult,
      dead:false, hitAnim:0, hp:td.hp, maxHp:td.hp,
      type, color:td.color||`hsl(${Math.random()*360},70%,65%)`,
      size:td.size, emoji:td.emoji,
    });
  }
  // Pozostałe boty fali w kolejce
  SN.waveQueue=[];
  for(let i=count;i<SN.waveSize;i++){
    let ni=Math.floor(Math.random()*BOT_NAMES.length);
    while(usedNames.has(ni)) ni=(ni+1)%BOT_NAMES.length;
    usedNames.add(ni);
    const type=sniper_botType(SN.wave);
    const td=BOT_TYPES[type];
    SN.waveQueue.push({
      name:BOT_NAMES[ni],
      speed:(0.0005+Math.random()*0.0004)*(1+SN.wave*0.08)*td.speedMult,
      hp:td.hp, maxHp:td.hp, type, color:td.color||`hsl(${Math.random()*360},70%,65%)`,
      size:td.size, emoji:td.emoji,
    });
  }
  document.getElementById('sniper-bot-level').textContent=`FALA ${SN.wave}/${SN_TOTAL_WAVES}`;
}

function sniper_addBotFromQueue(){
  if(!SN.waveQueue||SN.waveQueue.length===0) return;
  const usedLanes=new Set(SN.bots.filter(b=>!b.dead).map(b=>b.lane));
  let lane=-1;
  for(let i=0;i<SN_LANE_COUNT;i++) if(!usedLanes.has(i)){lane=i;break;}
  if(lane===-1) return;
  const q=SN.waveQueue.shift();
  SN.bots.push({...q, lane, progress:0, dead:false, hitAnim:0});
}

function sniper_botX(bot){
  return SN.canvas.width*0.06+(SN.canvas.width*0.88)*bot.progress;
}
function sniper_laneY(i){return SN.canvas.height*0.11+i*(SN.canvas.height*0.72/SN_LANE_COUNT);}
function sniper_laneH(){return SN.canvas.height*0.72/SN_LANE_COUNT;}

function sniper_shoot(x,y){
  if(!SN.active||SN.result) return;
  SN.shots.push({x,y,life:1,r:6,miss:true});
  for(const bot of SN.bots){
    if(bot.dead) continue;
    const bx=sniper_botX(bot);
    const by=sniper_laneY(bot.lane)+sniper_laneH()*0.5;
    const bs=sniper_laneH()*0.65*bot.size;
    if(Math.abs(x-bx)<bs*0.65&&Math.abs(y-by)<bs*0.65){
      SN.shots[SN.shots.length-1].miss=false;
      bot.hp--;
      // Trzęsienie
      const sc=document.getElementById('sniper-canvas');
      let shT=0;
      const shIv=setInterval(()=>{
        sc.style.transform=`translate(${(Math.random()-.5)*14}px,${(Math.random()-.5)*10}px)`;
        if(++shT>8){clearInterval(shIv);sc.style.transform='';}
      },30);
      if(bot.hp>0){
        // Trafiony ale żyje — flash
        bot.hitAnim=0.5;
        SN.shots.push({x,y,life:0.8,r:4,miss:false,partial:true});
        return;
      }
      // Zabity
      bot.dead=true; bot.hitAnim=1;
      SN.kills++;
      SN.waveDone++;
      document.getElementById('sniper-kills').textContent=SN.kills;
      // Następny bot z kolejki po chwili
      setTimeout(()=>{if(SN.active&&!SN.result)sniper_addBotFromQueue();},900);
      // Czy fala ukończona?
      if(SN.waveDone>=SN.waveSize){
        setTimeout(()=>{
          if(!SN.active||SN.result) return;
          SN.wave++;
          if(SN.wave>SN_TOTAL_WAVES){SN.result='win';sniper_showResult();return;}
          sniper_startWave();
        },1500);
      }
      return;
    }
  }
}

let sniper_raf=null;
function sniper_loop(){
  if(!SN.active) return;
  sniper_raf=requestAnimationFrame(sniper_loop);
  sniper_update();
  sniper_draw();
}

function sniper_update(){
  if(SN.result) return;
  SN.time+=1/60;
  SN.bgScroll+=1;
  document.getElementById('sniper-timer').textContent=SN.time.toFixed(1)+'s';
  for(const bot of SN.bots){
    if(bot.dead){bot.hitAnim=Math.max(0,bot.hitAnim-0.04);continue;}
    bot.progress+=bot.speed;
    // Ghost — miganie
    if(bot.type==='ghost') bot.ghost_vis=(Math.sin(Date.now()/200)*0.5+0.5);
    if(bot.progress>=1){SN.result='lose';sniper_showResult();return;}
  }
  SN.shots.forEach(s=>{s.life-=0.05;s.r+=1.5;});
  SN.shots=SN.shots.filter(s=>s.life>0);
}

function sniper_showResult(){
  const el=document.getElementById('sniper-result');
  el.style.display='flex';
  const li=19; // id poziomu Sniper
  if(SN.result==='win'){
    bestPcts[li]=100;
    updateBestTxt();
    document.getElementById('sniper-result-title').textContent='🎯 MISJA WYKONANA!';
    document.getElementById('sniper-result-sub').textContent=`Wszystkie ${SN_TOTAL_WAVES} fal pokonane! Czas: ${SN.time.toFixed(1)}s, Trafień: ${SN.kills}`;
  } else {
    const pct=Math.round((SN.wave/SN_TOTAL_WAVES)*100);
    if(pct>bestPcts[li]){ bestPcts[li]=pct; updateBestTxt(); }
    document.getElementById('sniper-result-title').textContent='❌ BOT UCIEKŁ!';
    document.getElementById('sniper-result-sub').textContent=`Fala ${SN.wave}/${SN_TOTAL_WAVES} — trafiłeś ${SN.kills} botów. Rekord: ${bestPcts[li]}%`;
  }
}

function sniper_draw(){
  const c=SN.canvas,ctx=SN.ctx,W=c.width,H=c.height;
  ctx.clearRect(0,0,W,H);
  const sky=ctx.createLinearGradient(0,0,0,H*0.55);
  sky.addColorStop(0,'#020508');sky.addColorStop(1,'#081520');
  ctx.fillStyle=sky;ctx.fillRect(0,0,W,H);
  // Budynki
  ctx.save();
  for(let i=0;i<16;i++){
    const bx=((i*157+SN.bgScroll*0.12)%(W+100))-50;
    const bh=H*(0.12+Math.sin(i*1.9)*0.1);
    const bw=W*0.05+i%3*W*0.02;
    ctx.fillStyle=`hsl(210,12%,${5+i%5*1.5}%)`;
    ctx.fillRect(bx,H*0.55-bh,bw,bh);
    for(let r=0;r<Math.ceil(bh/22);r++) for(let cc=0;cc<Math.ceil(bw/16);cc++){
      ctx.fillStyle=(i+r+cc)%3===0?'rgba(255,240,100,0.35)':'rgba(30,40,60,0.5)';
      ctx.fillRect(bx+cc*14+3,H*0.55-bh+r*20+4,9,12);
    }
  }
  ctx.restore();
  ctx.fillStyle='#0d1520';ctx.fillRect(0,H*0.55,W,H*0.45);

  // Info o fali na górze toru
  const trackX=W*0.05,trackW=W*0.9;
  ctx.fillStyle='rgba(255,255,255,0.5)';ctx.font=`bold ${H*0.022}px monospace`;
  ctx.textAlign='center';ctx.textBaseline='bottom';
  ctx.fillText(`FALA ${SN.wave}/${SN_TOTAL_WAVES} — ${SN.waveDone}/${SN.waveSize} pokonano`,W/2,sniper_laneY(0)-6);

  // Pasy torów
  for(let i=0;i<SN_LANE_COUNT;i++){
    const ty=sniper_laneY(i),th=sniper_laneH();
    const tg=ctx.createLinearGradient(0,ty,0,ty+th*0.82);
    tg.addColorStop(0,'rgba(8,18,38,0.92)');tg.addColorStop(1,'rgba(4,10,24,0.95)');
    ctx.fillStyle=tg;ctx.beginPath();ctx.roundRect(trackX,ty,trackW,th*0.82,5);ctx.fill();
    ctx.strokeStyle='rgba(0,120,220,0.3)';ctx.lineWidth=1.5;ctx.stroke();
    ctx.fillStyle='rgba(0,255,80,0.7)';ctx.fillRect(trackX,ty,3,th*0.82);
    ctx.fillStyle='rgba(255,40,40,0.7)';ctx.fillRect(trackX+trackW-3,ty,3,th*0.82);
    ctx.fillStyle='rgba(80,130,220,0.5)';ctx.font=`${th*0.2}px monospace`;
    ctx.textAlign='right';ctx.textBaseline='middle';
    ctx.fillText(`TOR ${i+1}`,trackX-6,ty+th*0.41);
    ctx.strokeStyle='rgba(0,80,180,0.08)';ctx.lineWidth=1;
    for(let gx=0;gx<trackW;gx+=W*0.05){ctx.beginPath();ctx.moveTo(trackX+gx,ty);ctx.lineTo(trackX+gx,ty+th*0.82);ctx.stroke();}
  }

  // Boty
  for(const bot of SN.bots){
    if(bot.dead&&bot.hitAnim<=0) continue;
    const bx=sniper_botX(bot);
    const ty=sniper_laneY(bot.lane);
    const th=sniper_laneH();
    const bs=th*0.65*bot.size;
    const by=ty+th*0.41-bs/2;
    ctx.save();
    // Ghost — półprzezroczysty
    if(bot.type==='ghost'&&!bot.dead) ctx.globalAlpha=0.35+Math.sin(Date.now()/180)*0.3;
    else ctx.globalAlpha=bot.dead?bot.hitAnim:1;

    // Kwadrat bota
    const col=bot.color||'#4488ff';
    ctx.fillStyle=col;ctx.shadowColor=col;ctx.shadowBlur=bot.dead?0:14;
    ctx.fillRect(bx-bs/2,by,bs,bs);
    // Biały border
    ctx.strokeStyle='rgba(255,255,255,0.9)';ctx.lineWidth=1.5;
    ctx.shadowColor='#fff';ctx.shadowBlur=6;
    ctx.strokeRect(bx-bs/2+0.75,by+0.75,bs-1.5,bs-1.5);
    ctx.shadowBlur=0;
    // Wzór
    ctx.fillStyle='rgba(255,255,255,0.3)';
    ctx.fillRect(bx-bs*0.15,by+bs*0.3,bs*0.3,bs*0.3);
    // Emoji typu
    if(bot.emoji){
      ctx.font=`${bs*0.55}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText(bot.emoji,bx,by+bs/2);
    }
    // HP pasek (dla hp>1)
    if(bot.maxHp>1&&!bot.dead){
      const bpw=bs;
      ctx.fillStyle='#333';ctx.fillRect(bx-bs/2,by-8,bpw,5);
      ctx.fillStyle=bot.hp===bot.maxHp?'#44ff44':'#ff4400';
      ctx.fillRect(bx-bs/2,by-8,bpw*(bot.hp/bot.maxHp),5);
      ctx.strokeStyle='rgba(255,255,255,0.4)';ctx.lineWidth=0.5;
      ctx.strokeRect(bx-bs/2,by-8,bpw,5);
    }
    // Trafiony ✕
    if(bot.dead){
      ctx.fillStyle=`rgba(255,50,50,${bot.hitAnim})`;
      ctx.font=`bold ${bs*1.1}px monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('✕',bx,by+bs/2);
    }
    // Nazwa + typ label
    ctx.fillStyle=bot.dead?`rgba(255,80,80,${bot.hitAnim})`:'rgba(255,255,255,0.9)';
    ctx.shadowColor=col;ctx.shadowBlur=4;
    ctx.font=`bold ${th*0.17}px monospace`;ctx.textAlign='center';ctx.textBaseline='bottom';
    ctx.fillText((BOT_TYPES[bot.type]?.label||'')+bot.name,bx,by-1);
    // %
    ctx.fillStyle='rgba(180,210,255,0.7)';ctx.shadowBlur=0;
    ctx.font=`${th*0.15}px monospace`;ctx.textBaseline='top';
    ctx.fillText(`${Math.floor(bot.progress*100)}%`,bx,by+bs+2);
    // Pasek postępu
    ctx.fillStyle=(col+'55');
    ctx.beginPath();ctx.roundRect(trackX,ty+th*0.82,trackW*bot.progress,th*0.1,2);ctx.fill();
    ctx.restore();
  }

  // Efekty strzałów
  for(const s of SN.shots){
    ctx.save();ctx.globalAlpha=s.life;
    if(s.miss){
      ctx.strokeStyle='#ff8800';ctx.lineWidth=2;ctx.shadowColor='#ff6600';ctx.shadowBlur=10;
      ctx.beginPath();ctx.moveTo(s.x-7,s.y-7);ctx.lineTo(s.x+7,s.y+7);ctx.stroke();
      ctx.beginPath();ctx.moveTo(s.x+7,s.y-7);ctx.lineTo(s.x-7,s.y+7);ctx.stroke();
    } else if(s.partial){
      // Trafienie w opancerzonego
      ctx.strokeStyle='#aaaaaa';ctx.lineWidth=2;ctx.shadowColor='#cccccc';ctx.shadowBlur=8;
      ctx.beginPath();ctx.arc(s.x,s.y,s.r*0.6,0,Math.PI*2);ctx.stroke();
    } else {
      ctx.strokeStyle='#ffff00';ctx.lineWidth=2.5;ctx.shadowColor='#ffff00';ctx.shadowBlur=25;
      ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);ctx.stroke();
      for(let a=0;a<8;a++){
        const ang=(a/8)*Math.PI*2;
        ctx.beginPath();ctx.moveTo(s.x+Math.cos(ang)*s.r*0.4,s.y+Math.sin(ang)*s.r*0.4);
        ctx.lineTo(s.x+Math.cos(ang)*s.r*2,s.y+Math.sin(ang)*s.r*2);ctx.stroke();
      }
    }
    ctx.restore();
  }
  // Linia celownika
  if(!SN.result){
    ctx.save();ctx.strokeStyle='rgba(0,255,0,0.06)';ctx.lineWidth=1;ctx.setLineDash([5,10]);
    ctx.beginPath();ctx.moveTo(W/2,H);ctx.lineTo(SN.scope.x,SN.scope.y);ctx.stroke();
    ctx.setLineDash([]);ctx.restore();
  }
  // Celownik
  if(!SN.result){
    const sx=SN.scope.x,sy=SN.scope.y,sr=42;
    ctx.save();
    ctx.fillStyle='rgba(0,0,0,0.6)';ctx.fillRect(0,0,W,H);
    ctx.save();ctx.globalCompositeOperation='destination-out';
    ctx.beginPath();ctx.arc(sx,sy,sr,0,Math.PI*2);ctx.fill();
    ctx.restore();
    ctx.strokeStyle='rgba(0,255,60,0.95)';ctx.lineWidth=2;ctx.shadowColor='#00ff44';ctx.shadowBlur=12;
    ctx.beginPath();ctx.arc(sx,sy,sr,0,Math.PI*2);ctx.stroke();
    ctx.beginPath();ctx.arc(sx,sy,sr*0.1,0,Math.PI*2);ctx.stroke();
    const gap=sr*0.2;ctx.lineWidth=1.5;
    [[1,0],[-1,0],[0,1],[0,-1]].forEach(([dx,dy])=>{
      ctx.beginPath();ctx.moveTo(sx+dx*gap,sy+dy*gap);ctx.lineTo(sx+dx*sr,sy+dy*sr);ctx.stroke();
    });
    ctx.strokeStyle='rgba(0,255,60,0.4)';ctx.lineWidth=1;
    [[1,1],[1,-1],[-1,1],[-1,-1]].forEach(([dx,dy])=>{
      ctx.beginPath();
      ctx.moveTo(sx+dx*sr*0.55,sy+dy*sr*0.4);ctx.lineTo(sx+dx*sr*0.55,sy+dy*sr*0.6);
      ctx.lineTo(sx+dx*sr*0.4,sy+dy*sr*0.6);ctx.stroke();
    });
    ctx.restore();
  }
  // HUD — fala + zabicia
  const barW=W*0.38,barH=10,barX=(W-barW)/2,barY=H-32;
  ctx.fillStyle='rgba(255,255,255,0.07)';ctx.beginPath();ctx.roundRect(barX,barY,barW,barH,5);ctx.fill();
  ctx.fillStyle='#00ff44';ctx.shadowColor='#00ff44';ctx.shadowBlur=8;
  ctx.beginPath();ctx.roundRect(barX,barY,barW*(SN.wave/SN_TOTAL_WAVES),barH,5);ctx.fill();
  ctx.shadowBlur=0;
  ctx.fillStyle='rgba(255,255,255,0.7)';ctx.font='11px monospace';ctx.textAlign='center';ctx.textBaseline='bottom';
  ctx.fillText(`FALA ${SN.wave}/${SN_TOTAL_WAVES} • Trafień: ${SN.kills}`,W/2,barY-3);
  // Legenda typów botów w rogu
  ctx.save();
  const types=[['⚡ Szybki','#ffee00'],['🛡️ Tank','#888888'],['🔒 Pancerny (2x)','#cc8800'],['👻 Duch','rgba(200,200,255,0.8)']];
  ctx.font=`${H*0.018}px monospace`;ctx.textAlign='left';ctx.textBaseline='top';
  types.forEach(([label,col],i)=>{
    ctx.fillStyle=col;ctx.fillText(label,W*0.01,H*0.92+i*H*0.02);
  });
  ctx.restore();
}
