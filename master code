function seSetupCanvas(){
  const cv=document.getElementById('se-canvas');
  if(!cv) return;
  const paint=(e)=>{
    if(!seDrawing) return;
    const r=cv.getBoundingClientRect();
    const cw=cv.width/SE_SIZE, ch=cv.height/SE_SIZE;
    const cx=e.touches?e.touches[0].clientX:e.clientX;
    const cy2=e.touches?e.touches[0].clientY:e.clientY;
    const col=Math.floor((cx-r.left)/cw);
    const row=Math.floor((cy2-r.top)/ch);
    if(col<0||col>=SE_SIZE||row<0||row>=SE_SIZE) return;
    sePages[sePage][row*SE_SIZE+col]=seTool==='erase'?null:seColor;
    seRender();
  };
  cv.onmousedown=(e)=>{seDrawing=true;paint(e);};
  cv.onmousemove=paint;
  cv.onmouseup=()=>seDrawing=false;
  cv.onmouseleave=()=>seDrawing=false;
  cv.ontouchstart=(e)=>{e.preventDefault();seDrawing=true;paint(e);};
  cv.ontouchmove=(e)=>{e.preventDefault();paint(e);};
  cv.ontouchend=()=>seDrawing=false;
}

function seRender(){
  const cv=document.getElementById('se-canvas');
  if(!cv) return;
  const ctx2=cv.getContext('2d');
  const cw=cv.width/SE_SIZE, ch=cv.height/SE_SIZE;
  ctx2.clearRect(0,0,cv.width,cv.height);
  for(let r=0;r<SE_SIZE;r++) for(let c=0;c<SE_SIZE;c++){
    ctx2.fillStyle=(r+c)%2===0?'#1a1a2e':'#12122a';
    ctx2.fillRect(c*cw,r*ch,cw,ch);
  }
  sePages[sePage].forEach((col2,i)=>{
    if(!col2) return;
    const r=Math.floor(i/SE_SIZE),c=i%SE_SIZE;
    ctx2.fillStyle=col2;
    ctx2.fillRect(c*cw,r*ch,cw,ch);
  });
  ctx2.strokeStyle='rgba(255,255,255,0.06)';ctx2.lineWidth=0.5;
  for(let i=0;i<=SE_SIZE;i++){
    ctx2.beginPath();ctx2.moveTo(i*cw,0);ctx2.lineTo(i*cw,cv.height);ctx2.stroke();
    ctx2.beginPath();ctx2.moveTo(0,i*ch);ctx2.lineTo(cv.width,i*ch);ctx2.stroke();
  }
  [['se-preview',64],['se-preview-big',128]].forEach(([id,sz])=>{
    const pv=document.getElementById(id);
    if(!pv) return;
    pv.style.imageRendering=sePixelMode?'pixelated':'auto';
    const pc=pv.getContext('2d');
    pc.clearRect(0,0,sz,sz);
    pc.fillStyle='#0a0a1a';pc.fillRect(0,0,sz,sz);
    const ps=sz/SE_SIZE;
    sePages[sePage].forEach((col2,i)=>{
      if(!col2) return;
      const r=Math.floor(i/SE_SIZE),c=i%SE_SIZE;
      pc.fillStyle=col2;pc.fillRect(c*ps,r*ps,ps,ps);
    });
    if(seBorder){
      pc.strokeStyle=seBorderColor||'#ffffff';
      pc.lineWidth=2;
      pc.shadowColor=seBorderColor||'#ffffff';
      pc.shadowBlur=seBorderBlur||8;
      pc.strokeRect(1,1,sz-2,sz-2);
      pc.shadowBlur=0;
    }
  });
}

