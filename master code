function updateLivesUI(){
  const total=currentLevel.lives;
  if(total<=1){ jumpsUI.textContent=`SKOKI: ${jumps}`; return; }
  const hearts='❤️'.repeat(Math.max(0,lives))+'🖤'.repeat(Math.max(0,total-lives));
  jumpsUI.textContent=hearts;
}

function reset(){
  loadShopSkinsIntoArray(); // upewnij się że efekty skina są załadowane
  const lv=currentLevel;
  player.y=GROUND-TILE; player.vy=0; player.onGround=true; player.onPlatform=false;
  player.rotation=0; player.doubleJumps=0; player.usedDoubleJump=false;
  jumps=0; obstacles=[]; orbs=[]; platforms=[]; levelProgress=0; levelTime=0;
  speed=lv.speedBase; nextSpawnX=W+150;
  particles=[]; trail=[]; themeIdx=0; theme=lv.themes[0];
  fxTimer=0; fxActive=false; fxAlpha=0; fxOverlay.style.opacity='0';
  hardcoreTimer=0; cameraY=0; infiniteMilestone=0;
  flyMode=false; flySpikes=[]; flyPortals=[]; flySpawnTimer=0; flyPortalSpawnX=lv&&lv.custom?999999:-TILE*80; flyDistance=0; flyInvincible=0;
  generateStars();
  if(lv.isCity) cityInit();
  if(lv.is3D) d3_init();
  if(lv.custom){
    // Załaduj obiekty z edytora
    obstacles=[...lv.customObstacles.map(o=>({...o}))];
    orbs=[...lv.customOrbs.map(o=>({...o}))];
    platforms=[...lv.customPlatforms.map(p=>({...p}))];
    flyPortals=[...lv.customPortals.map(p=>({...p}))];
    nextSpawnX=999999; // nie generuj losowych
  } else {
    for(let i=0;i<10;i++) nextSpawnX=spawnChunk(nextSpawnX,lv);
  }
}

let flyUp=false, flyDown=false, flyPortalEntryX=W*0.2;

function jump(){
  if(state!=='playing') return;
  if(flyMode) return;
  if(player.onGround||player.onPlatform){
    player.vy=JUMP_FORCE; player.onGround=false; player.onPlatform=false;
    player.usedDoubleJump=false; jumps++;
    spawnParticles(player.x,player.y+player.size,'#40c0f0',10);
  } else if(player.doubleJumps>0&&!player.usedDoubleJump){
    player.vy=JUMP_FORCE*0.88; player.doubleJumps--; player.usedDoubleJump=true; jumps++;
    spawnParticles(player.x+player.size/2,player.y+player.size/2,'#e060ff',22);
  }
}

function flyHit(){
  if(state==='dead') return;
  lives--;
  updateLivesUI();
  spawnParticles(player.x+player.size/2,player.y+player.size/2,'#00ffff',20);
  flash.style.opacity='1'; setTimeout(()=>{flash.style.opacity='0';},150);
  if(lives<=0){ flyMode=false; hideFlyControls(); die(); return; }
  // Odrodź się w środku przestrzeni latania (między sufitem a podłogą)
  player.x = W*0.2;
  player.y = (GROUND - player.size) / 2;
  flyVy=0;
  flySpikes=[];
  flyDistance=0;
  flyInvincible=120;
}

