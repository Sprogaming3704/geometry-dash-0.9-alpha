}
.pause-btn-row{display:flex;gap:16px;}
.pause-action{
  padding:12px 36px;font-family:'Russo One',sans-serif;font-size:18px;
  border:none;border-radius:8px;color:#fff;cursor:pointer;
  transition:transform 0.1s;
}
.pause-action:hover{transform:scale(1.05);}
#pause-resume{background:linear-gradient(135deg,#30c060,#20a040);}
#pause-menu{background:linear-gradient(135deg,#555,#333);}
/* Fly mode controls */
#fly-controls{
  position:absolute;bottom:20px;left:50%;transform:translateX(-50%);
  display:none;gap:20px;z-index:11;
}
.fly-btn{
  width:80px;height:80px;border-radius:50%;
  background:rgba(0,200,255,0.2);border:3px solid rgba(0,200,255,0.6);
  color:#fff;font-size:36px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  user-select:none;-webkit-user-select:none;
  transition:background 0.1s;
}
.fly-btn:active{background:rgba(0,200,255,0.5);}

#mobile-btn{
  position:fixed;
  bottom:0;
  left:0;right:0;
  height:80px;
  background:linear-gradient(135deg,#30d060,#20a040);
  border:none;
  border-top:3px solid #50ff80;
  color:#fff;
  font-family:'Russo One',sans-serif;
  font-size:28px;
  display:flex;
  align-items:center;justify-content:center;
  z-index:25;
  cursor:pointer;
  user-select:none;
  -webkit-user-select:none;
  letter-spacing:2px;
  box-shadow:0 -4px 20px rgba(40,200,80,0.4);
  transition:background 0.1s, box-shadow 0.1s;
}
#mobile-btn:active{background:linear-gradient(135deg,#50ff80,#30c060);box-shadow:0 -4px 40px rgba(40,255,80,0.7);}

