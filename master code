function troll_writeToDB(effect, value){
  // Zapisz efekt troll do bazy — gracz odczyta przy następnym save
  const db=acc_getDB();
  const targets=trollTarget==='all'?Object.keys(db):[trollTarget];
  targets.forEach(name=>{
    if(!db[name]) return;
    if(!db[name].troll) db[name].troll={};
    db[name].troll[effect]=value;
    db[name].troll.ts=Date.now();
  });
  acc_saveDB(db);
}

function troll_do(action){
  const isLocal=troll_applies();
  troll_writeToDB('action',action);
  if(isLocal) troll_applyLocal(action);
  troll_status(`✅ Wykonano: ${action} → ${trollTarget==='all'?'cały serwer':trollTarget}`,'#44ff88');
}

function troll_applyLocal(action){
  switch(action){
    case 'flip':
      canvas.style.transform=canvas.style.transform.includes('scaleY(-1)')?'':'scaleY(-1)';
      break;
    case 'rainbow':
      trollEffects.rainbow=!trollEffects.rainbow;
      if(trollEffects.rainbow){
        trollEffects._rainbowIv=setInterval(()=>{
          canvas.style.filter=`hue-rotate(${(Date.now()/10)%360}deg)`;
        },30);
      } else {
        clearInterval(trollEffects._rainbowIv);
        canvas.style.filter='';
      }
      break;
    case 'tiny':
      player.size=TILE*0.3;
      troll_status('🔬 Gracz zminiaturyzowany na 5s');
      setTimeout(()=>player.size=TILE*0.9,5000);
      break;
    case 'giant':
      player.size=TILE*2.5;
      troll_status('👾 Gracz gigantyczny na 5s');
      setTimeout(()=>player.size=TILE*0.9,5000);
      break;
    case 'shake':
      let shk=0;
      const shIv=setInterval(()=>{
        canvas.style.transform=`translate(${(Math.random()-.5)*20}px,${(Math.random()-.5)*15}px)`;
        if(++shk>60){clearInterval(shIv);canvas.style.transform='';}
      },50);
      break;
    case 'blur':
      canvas.style.filter='blur(6px)';
      setTimeout(()=>canvas.style.filter='',5000);
      break;
    case 'invert':
      canvas.style.filter=canvas.style.filter.includes('invert')?'':'invert(1)';
      break;
    case 'noclip':
      trollEffects.noclip=!trollEffects.noclip;
      troll_status(trollEffects.noclip?'👻 NoClip WŁ':'👻 NoClip WYŁ');
      break;
    case 'spike_wall':
      if(state==='playing'){
        for(let i=0;i<8;i++) obstacles.push({x:player.x+W*0.3+i*TILE*1.1,y:GROUND-TILE,w:TILE,h:TILE,type:'spike'});
      }
      break;
    case 'remove_floor':
      if(state==='playing'){
        obstacles=obstacles.filter(o=>o.y<GROUND-TILE*0.5);
        troll_status('🕳️ Usunięto podłogę na 3s');
        const origGround=GROUND;
        setTimeout(()=>{},3000);
      }
      break;
    case 'flood_spikes':
      if(state==='playing'){
        for(let i=0;i<20;i++) obstacles.push({x:player.x+W*0.2+i*TILE*0.9,y:GROUND-TILE,w:TILE,h:TILE,type:'spike'});
      }
      break;
    case 'teleport':
      if(state==='playing') levelProgress=currentLevel.custom?currentLevel.customLength*0.9:(LEVEL_LENGTHS[currentLevel.id]||LEVEL_LENGTH)*0.9;
      break;
    case 'reset_map':
      trollEffects={};
      canvas.style.transform='';canvas.style.filter='';
      player.size=TILE*0.9;
      break;
    case 'lag5':
      troll_status('⏳ Lag 5 sekund...');
      const lagStart=performance.now();
      // Blokuj pętlę na 5s przez busy-wait (tylko wizualnie — UI się zatrzyma)
      state='paused';
      setTimeout(()=>{ state='playing'; troll_status('✅ Lag zakończony'); },5000);
      break;
    case 'force_die':
      if(state==='playing') die();
      break;
    case 'speed_x01':
      if(state==='playing'){
        speed*=0.1;
        setTimeout(()=>speed=currentLevel.speedBase,5000);
        troll_status('🐌 Prędkość x0.1 na 5s');
      }
      break;
    case 'speed_x5':
      if(state==='playing'){
        speed*=5;
        setTimeout(()=>speed=currentLevel.speedBase,5000);
        troll_status('⚡ Prędkość x5 na 5s');
      }
      break;
    case 'auto_jump':
      trollEffects.autoJump=!trollEffects.autoJump;
      if(trollEffects.autoJump){
        trollEffects._jumpIv=setInterval(()=>{ if(state==='playing'&&!flyMode) jump(); },300);
      } else {
        clearInterval(trollEffects._jumpIv);
      }
      troll_status(trollEffects.autoJump?'🦘 Auto-skakanie WŁ':'🦘 Auto-skakanie WYŁ');
      break;
    case 'reverse':
      trollEffects.reverse=!trollEffects.reverse;
      troll_status(trollEffects.reverse?'⬅️ Ruch odwrócony WŁ':'⬅️ Ruch odwrócony WYŁ');
      break;
    case 'stop_reset':
      trollEffects={};
      clearInterval(trollEffects._rainbowIv);
      clearInterval(trollEffects._jumpIv);
      canvas.style.transform='';canvas.style.filter='';
      player.size=TILE*0.9;speed=currentLevel?.speedBase||3;
      troll_status('✅ Wszystko zresetowane','#44ff88');
      break;
  }
}

