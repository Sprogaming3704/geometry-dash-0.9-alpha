function startGame(lvIdx){
  currentLevel=LEVELS[lvIdx];
  if(!currentLevel){ console.error('Brak poziomu',lvIdx); return; }
  if(currentLevel.isSniper){
    lives=currentLevel.lives; state='playing';
    screenEl.style.display='none';
    document.getElementById('mobile-btn').style.display='none';
    document.getElementById('pause-btn').style.display='flex';
    sniper_open(); return;
  }
  // Custom level — krótsze ładowanie
  const loadTime=currentLevel.custom?250:420;
  screenEl.style.display='none';
  document.getElementById('mobile-btn').style.display='none';
  document.getElementById('pause-btn').style.display='none';
  levelLoading_show(lvIdx, loadTime, ()=>{
    lives=currentLevel.lives; state='playing';
