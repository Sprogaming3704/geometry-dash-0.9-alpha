function doLogin(){
  const name=document.getElementById('l-name').value.trim();
  const pin=document.getElementById('l-pin').value.trim();
  const err=document.getElementById('login-err');
  err.textContent='';
  if(!name){err.textContent='Podaj nazwę gracza!';return;}
  if(pin.length!==4||!/^\d{4}$/.test(pin)){err.textContent='PIN musi mieć 4 cyfry!';return;}
  // Specjalne konta bez kodu (Tester) — można logować normalnie
  if(SPECIAL_ACCOUNTS[name]){
    const sp=SPECIAL_ACCOUNTS[name];
    if(sp.code){err.textContent='Użyj zakładki 👑 ADMIN/OWNER!';return;}
    if(!_v(pin,sp._p)){err.textContent='Błędny PIN!';return;}
    currentUser=name;
    applySpecialAccount(sp);
    loginSuccess(name);
    return;
  }
  const db=acc_getDB();
  if(!db[name]){err.textContent='Nie ma takiego gracza!';return;}
  if(db[name].pin!==pin){err.textContent='Błędny PIN!';return;}
  // Sprawdź ban
  const ud=db[name];
  if(ud.banned&&(!ud.banUntil||Date.now()<ud.banUntil)){
    const until=ud.banUntil?`do ${new Date(ud.banUntil).toLocaleDateString('pl-PL')}`:'permanentnie';
    err.textContent=`⛔ Jesteś zbanowany ${until}. Powód: ${ud.banReason||'?'}`;
    return;
  }
  currentUser=name;
  currentRole='user'; currentBadge='';
  acc_loadProgress();
  loginSuccess(name);
}


