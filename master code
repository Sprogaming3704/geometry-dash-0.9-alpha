    // Pokaż komunikat
    const sub=document.getElementById('screen-sub');
    sub.style.color='#ff8844';
    sub.textContent='Ukończ poziom BÓSTWO (Świat 1) żeby odblokować Świat Wody!';
    setTimeout(()=>{sub.style.color='';sub.textContent='Wybierz poziom';},3000);
    return;
  }
  currentWorld=w;
  levelPage=0;
  selectedLevel=null;
  if(actionBtn) actionBtn.style.display='none';
  // Aktualizuj przyciski świata
  for(let i=1;i<=2;i++){
    const btn=document.getElementById(`world-btn-${i}`);
    if(!btn) continue;
    const wdata=WORLDS[i-1];
    btn.style.background=i===w?`rgba(${i===1?'48,192,96':'0,170,255'},0.2)`:'rgba(255,255,255,0.04)';
    btn.style.borderColor=i===w?(i===1?'#30c060':'#00aaff'):'#333';
    btn.style.color=i===w?(i===1?'#80ff80':'#44eeff'):'#666';
    btn.style.borderWidth=i===w?'2px':'1px';
  }
  // Ładowanie świata
  if(w===2){
    const barWrap=document.getElementById('world-loading-bar-wrap');
    const bar=document.getElementById('world-loading-bar');
    const txt=document.getElementById('world-loading-text');
    barWrap.style.display='block';txt.style.display='block';
    const wSteps=[
      [10,'🌊 Inicjalizacja Świata Wody...'],[25,'🐠 Ładowanie fauny morskiej...'],
      [40,'🌿 Generowanie raf koralowych...'],[55,'🦈 Kalibracja trudności...'],
      [70,'🫧 Tworzenie efektów wodnych...'],[85,'🌊 Finalizacja poziomów...'],
      [100,'✅ Świat Wody gotowy!'],
    ];
    let si=0;
    const run=()=>{
      if(si>=wSteps.length){
        setTimeout(()=>{barWrap.style.display='none';txt.style.display='none';buildLevelGrid();},400);
        return;
      }
      const [pct,label]=wSteps[si++];
      bar.style.width=pct+'%';txt.textContent=label;
      setTimeout(run,300+Math.random()*200);
    };
    run();
  } else {
    buildLevelGrid();
  }
}

function buildLevelGrid(){
  levelGrid.innerHTML='';
  // Filtruj poziomy aktualnego świata
  const worldLevels=LEVELS.filter(lv=>
    currentWorld===1 ? (lv.world===undefined||lv.world===1) && lv.id<=20
                     : lv.world===currentWorld
  );
  const totalPages=Math.ceil(worldLevels.length/LEVELS_PER_PAGE);
  if(levelPage>=totalPages) levelPage=0;
  const start=levelPage*LEVELS_PER_PAGE;
  const end=Math.min(start+LEVELS_PER_PAGE, worldLevels.length);

  const prevBtn=document.createElement('button');
  prevBtn.className='page-arrow';
  prevBtn.textContent='◀';
  prevBtn.disabled=levelPage===0;
  prevBtn.onclick=()=>{ levelPage--; selectedLevel=null; actionBtn.style.display='none'; buildLevelGrid(); };
  levelGrid.appendChild(prevBtn);

  const grid=document.createElement('div');
  grid.style.cssText='display:flex;gap:8px;flex-wrap:wrap;justify-content:center;flex:1;';
  for(let i=start;i<end;i++){
    const lv=worldLevels[i];
    const li=lv.id;
    const btn=document.createElement('button');
    btn.className='lvl-btn'+(unlockedLevels[li]?'':' locked');
    btn.style.background=`linear-gradient(135deg,${lv.color}55,${lv.color}22)`;
    btn.style.border=`2px solid ${lv.color}88`;
    btn.style.boxShadow=`0 0 16px ${lv.color}44`;
    const bestVal=lv.isSniper
      ? (bestPcts[li]>0 ? `FALA ${Math.round(bestPcts[li]/100*SN_TOTAL_WAVES)}/${SN_TOTAL_WAVES}` : '—')
      : lv.infinite?(bestPcts[li]>0?bestPcts[li]+'m':'—'):(bestPcts[li]>0?bestPcts[li]+'%':'—');
    btn.innerHTML=`<span class="icon">${lv.icon}</span><span>${lv.name}</span><div class="lname">BEST: ${bestVal}</div>`;
    if(unlockedLevels[li]) btn.onclick=()=>selectLevel(li);
    grid.appendChild(btn);
  }
  levelGrid.appendChild(grid);

  const nextBtn=document.createElement('button');
  nextBtn.className='page-arrow';
  nextBtn.textContent='▶';
  nextBtn.disabled=levelPage>=totalPages-1;
  nextBtn.onclick=()=>{ levelPage++; selectedLevel=null; actionBtn.style.display='none'; buildLevelGrid(); };
  levelGrid.appendChild(nextBtn);

  const pageInd=document.createElement('div');
  pageInd.style.cssText='width:100%;text-align:center;font-size:12px;color:#666;margin-top:4px;font-family:"Russo One",sans-serif;';
  const wName=currentWorld===2?'🌊 Świat Wody':'🌍 Świat 1';
  pageInd.textContent=`${wName} · ${levelPage+1} / ${totalPages}`;
  levelGrid.appendChild(pageInd);
}

function buildCitySkinGrid(){
