  }
  acc_saveDB(db);
  localStorage.setItem('gd_last_user',currentUser);
}

function acc_loadProgress(){
  if(!currentUser) return;
  const db=acc_getDB();
  const u=db[currentUser];
  if(!u) return;
  if(u.bestPcts&&u.bestPcts.length) bestPcts=u.bestPcts;
  if(u.unlockedLevels&&u.unlockedLevels.length) unlockedLevels=u.unlockedLevels;
