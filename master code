function musicPlayGame(levelId, trackId){
  // Zawsze restartuj muzykę dla poziomu
  musicStop();audioInit();
  if(audioCtx.state==='suspended') audioCtx.resume();
  musicPlaying='game';

  const track=MUSIC_TRACKS[trackId!==undefined ? trackId%MUSIC_TRACKS.length : levelId%MUSIC_TRACKS.length];
  const b=60/track.bpm, t=audioCtx.currentTime+0.05;
  const sc=track.scale;
  const pat=track.pattern.map(i=>sc[i%sc.length]);

  function bar(s){
    if(musicPlaying!=='game') return;
    // Lead
    pat.forEach((f,i)=>{
      makeOsc(f, track.leadType, s+i*b*track.noteLen, b*track.noteDur, track.leadVol, 0.005, 0.03);
      if(track.octaveDouble) makeOsc(f*2,'sine',s+i*b*track.noteLen,b*track.noteDur*0.6,track.leadVol*0.3,0.005,0.03);
    });
    // Bas
    track.bassRhythm.forEach(q=>makeOsc(sc[0]/2*(track.bassOct||1), track.bassType||'square', s+q*b, b*0.22, track.bassVol||0.14, 0.003, 0.04));
    // Chords
    if(track.chords){
      track.chords.forEach((chord,ci)=>{
        chord.forEach(f=>makeOsc(f,'sine',s+ci*b*2,b*1.9,0.035,0.1,0.2));
      });
    }
    // Drums
    track.kicks.forEach(q=>makeKick(s+q*b, track.kickVol||0.5));
    track.snares.forEach(q=>makeSnare(s+q*b, track.snareVol||0.18));
    const hats=track.hats||16;
    for(let i=0;i<hats;i++) makeHat(s+i*b*(4/hats), track.hatVol||0.028);
    setTimeout(()=>{if(musicPlaying==='game')bar(s+b*4);},(s+b*4-audioCtx.currentTime)*1000-80);
  }
  bar(t);
}

